<view class="container">
  <view class="card">
    <view style="font-weight: 600; font-size: 32rpx; margin-bottom: 12rpx;">契约号：{{detail.contractNo}}</view>
    <view class="row">
      <text class="text-muted">状态</text>
      <text>{{detail.status}}</text>
    </view>
    <view class="row">
      <text class="text-muted">保证金</text>
      <text>{{detail.depositAmount}}</text>
    </view>
    <view class="row">
      <text class="text-muted">服务费</text>
      <text>{{detail.serviceFeeAmount}}</text>
    </view>
    <view class="row">
      <text class="text-muted">创建时间</text>
      <text>{{detail.createTime}}</text>
    </view>
  </view>

  <view class="card">
    <view style="font-weight: 600; margin-bottom: 12rpx;">参与方</view>
    <view class="row">
      <text class="text-muted">发起人</text>
      <text>{{detail.initiator.nickname}} ({{detail.initiator.userId}})</text>
    </view>
    <view class="row">
      <text class="text-muted">发起人游戏ID</text>
      <text>{{detail.initiator.gameId}}</text>
    </view>
    <view class="row">
      <text class="text-muted">接收人</text>
      <text>{{detail.receiver.nickname}} ({{detail.receiver.userId}})</text>
    </view>
    <view class="row">
      <text class="text-muted">接收人游戏ID</text>
      <text>{{detail.receiver.gameId}}</text>
    </view>
  </view>

  <view class="card">
    <view style="font-weight: 600; margin-bottom: 12rpx;">条款</view>
    <view class="row">
      <text class="text-muted">游戏类型</text>
      <text>{{detail.gameType}}</text>
    </view>
    <view class="row">
      <text class="text-muted">游戏大区</text>
      <text>{{detail.gameRegion}}</text>
    </view>
    <view class="row">
      <text class="text-muted">保底物品</text>
      <text>{{detail.guaranteeItem}}</text>
    </view>
    <view class="row">
      <text class="text-muted">成功条件</text>
      <text>{{detail.successCondition}}</text>
    </view>
    <view class="row">
      <text class="text-muted">失败条件</text>
      <text>{{detail.failureCondition}}</text>
    </view>
  </view>
</view>
