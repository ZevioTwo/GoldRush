<view class="container">
  <view class="card">
    <view class="detail-title">契约号：{{detail.contractNo}}</view>
    <view class="row">
      <text class="text-muted">状态</text>
      <text>{{detail.status}}</text>
    </view>
    <view class="row">
      <text class="text-muted">保证金</text>
      <text>{{detail.depositAmount}}</text>
    </view>
    <view class="row">
      <text class="text-muted">服务费</text>
      <text>{{detail.serviceFeeAmount}}</text>
    </view>
    <view class="row">
      <text class="text-muted">创建时间</text>
      <text>{{detail.createTime}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">参与方</view>
    <view class="row">
      <text class="text-muted">发起人</text>
      <text>{{detail.initiator.nickname}} ({{detail.initiator.userId}})</text>
    </view>
    <view class="row">
      <text class="text-muted">接收人</text>
      <text>{{detail.receiver ? (detail.receiver.nickname + ' (' + detail.receiver.userId + ')') : '待接收'}}</text>
    </view>
  </view>

  <view class="card">
    <view class="section-title">条款</view>
    <view class="row">
      <text class="text-muted">标题</text>
      <text>{{detail.title}}</text>
    </view>
    <view class="row">
      <text class="text-muted">契约达成条件</text>
      <text>{{detail.successCondition}}</text>
    </view>
  </view>

  <button class="btn-outline" bindtap="goDisputeApply">申请仲裁</button>
</view>
