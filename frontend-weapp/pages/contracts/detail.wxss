.detail-title {
  font-weight: 700;
  font-size: 32rpx;
  margin-bottom: 12rpx;
  letter-spacing: 0.6rpx;
  color: #111827;
}

.section-title {
  font-weight: 700;
  margin-bottom: 12rpx;
  color: #111827;
}

.parchment-card {
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
}

.wax-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28);
}

.wax-btn::after {
  border: none;
}

.stamp-area {
  position: relative;
  height: 120rpx;
  margin: 8rpx 0 16rpx;
}

.stamp {
  position: absolute;
  right: 30rpx;
  top: 10rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(59, 130, 246, 0.7);
  color: rgba(59, 130, 246, 0.7);
  font-weight: 700;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-12deg) scale(0.6);
  opacity: 0;
  animation: stamp 0.6s ease-out forwards;
  background: radial-gradient(circle at 30% 30%, rgba(239, 246, 255, 0.9), rgba(255, 255, 255, 0.2));
}

.stamp::after {
  content: "已盖章";
}

@keyframes stamp {
  0% {
    transform: translateY(-40rpx) rotate(-12deg) scale(0.2);
    opacity: 0;
  }
  60% {
    transform: translateY(0) rotate(-12deg) scale(1.1);
    opacity: 1;
  }
  100% {
    transform: translateY(0) rotate(-12deg) scale(1);
    opacity: 1;
  }
}
