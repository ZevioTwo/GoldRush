.detail-page {
  background: var(--color-background);
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.banner {
  height: 340rpx;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at top right, rgba(252, 196, 25, 0.2), transparent 35%),
    linear-gradient(180deg, #f7f2e2 0%, #ddd9cf 100%);
}

.banner--placeholder {
  background:
    radial-gradient(circle at top right, rgba(252, 196, 25, 0.22), transparent 34%),
    radial-gradient(circle at bottom left, rgba(255, 255, 255, 0.75), transparent 30%),
    linear-gradient(180deg, #f3efe6 0%, #d7d1c5 100%);
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-fallback {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.banner-fallback-icon {
  width: 132rpx;
  height: 132rpx;
  opacity: 0.9;
}

.banner-fallback-game {
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.88);
  letter-spacing: 3rpx;
}

.banner-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.6) 100%);
}

.status-badge {
  position: absolute;
  left: 32rpx;
  bottom: 32rpx;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  color: #fff;
  background: #22c55e;
  letter-spacing: 2rpx;
}

.status-badge.warning {
  background: #d9a42b;
}

.status-badge.info {
  background: #339af0;
}

.status-badge.success {
  background: #22c55e;
}

.status-badge.danger {
  background: #fa5252;
}

.content {
  padding: 0 24rpx;
  margin-top: -72rpx;
}

.detail-card.large {
  background: #fff;
  border-radius: 48rpx;
  padding: 36rpx;
  box-shadow: 0 -20rpx 60rpx rgba(0,0,0,0.08);
  border: 1rpx solid rgba(0,0,0,0.05);
}

.tag-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.game-tag {
  background: #fcf8e8;
  color: #d9a42b;
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 900;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
}

.contract-id {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.4);
  font-weight: 700;
}

.title {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-foreground);
  margin-bottom: 20rpx;
  line-height: 1.25;
}

.meta-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
  font-size: 22rpx;
  color: var(--color-muted-foreground);
  font-weight: 700;
  flex-wrap: wrap;
}

.risk-banner {
  background: rgba(252, 248, 232, 0.4);
  border: 1rpx solid rgba(217, 164, 43, 0.1);
  border-radius: 36rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.risk-title {
  font-size: 20rpx;
  color: rgba(217, 164, 43, 0.6);
  font-weight: 900;
  letter-spacing: 2rpx;
}

.risk-desc {
  font-size: 24rpx;
  color: var(--color-muted-foreground);
  font-weight: 700;
}

.risk-right {
  text-align: right;
}

.risk-value {
  font-size: 36rpx;
  font-weight: 900;
  color: #d9a42b;
}

.issuer-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(252, 248, 232, 0.3);
  border: 1rpx solid rgba(217, 164, 43, 0.05);
  border-radius: 32rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.issuer-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.issuer-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  border: 2rpx solid #fff;
  background: #f1f3f5;
  flex-shrink: 0;
}

.issuer-copy {
  min-width: 0;
}

.issuer-name {
  font-size: 28rpx;
  font-weight: 900;
  color: var(--color-foreground);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.issuer-sub {
  font-size: 20rpx;
  color: #d9a42b;
  font-weight: 700;
  display: block;
}

.issuer-btn {
  background: #fff;
  color: #d9a42b;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  font-size: 20rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.issuer-btn::after,
.action-btn::after {
  border: none;
}

.tabs {
  display: flex;
  gap: 12rpx;
  background: #f8f9fa;
  border-radius: 24rpx;
  padding: 8rpx;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 900;
  color: rgba(142, 154, 175, 0.7);
}

.tab.active {
  background: #fff;
  color: #d9a42b;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.06);
}

.section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 24rpx;
  font-weight: 900;
  color: var(--color-foreground);
  margin-bottom: 12rpx;
}

.section-body {
  background: #f8f9fa;
  border-radius: 32rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: var(--color-muted-foreground);
  border: 1rpx solid rgba(0,0,0,0.03);
  white-space: pre-wrap;
  word-break: break-word;
}

.term-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.term-dot {
  width: 12rpx;
  height: 12rpx;
  background: #fcf8e8;
  border-radius: 50%;
  margin-top: 10rpx;
}

.term-text {
  font-size: 24rpx;
  color: var(--color-muted-foreground);
  flex: 1;
}

.footer-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 40rpx;
  background: rgba(255, 255, 255, 0.92);
  border-top: 1rpx solid rgba(0,0,0,0.05);
}

.countdown-chip {
  margin-bottom: 12rpx;
  padding: 14rpx 18rpx;
  border-radius: 20rpx;
  background: #fff9db;
  color: #d9a42b;
  border: 1rpx solid rgba(217, 164, 43, 0.16);
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
}

.action-btn {
  width: 100%;
  border-radius: 28rpx;
  font-size: 28rpx;
  margin-top: 12rpx;
  font-weight: 900;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
}

.action-btn.secondary {
  background-color: #f1f3f5;
  color: #868e96;
}

.action-btn::after {
  border: none;
}
