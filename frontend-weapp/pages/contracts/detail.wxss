.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.detail-card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.detail-title {
  font-weight: 700;
  font-size: 32rpx;
  color: #111827;
}

.section-title {
  font-weight: 700;
  margin-bottom: 12rpx;
  color: #111827;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
  color: #666;
}

.label {
  color: #999;
}

.value {
  color: #333;
}

.status-tag {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  color: #666;
}

.countdown-text {
  color: #dc2626;
  font-weight: 600;
}

.action-btn {
  width: 100%;
  border-radius: 10rpx;
  font-size: 30rpx;
  margin-top: 16rpx;
}

.action-btn.primary {
  background-color: #FFC107;
  color: #333;
}

.action-btn.secondary {
  background-color: #f0f0f0;
  color: #666;
}

.action-btn::after {
  border: none;
}

.stamp-area {
  position: relative;
  height: 120rpx;
  margin: 8rpx 0 16rpx;
}

.stamp {
  position: absolute;
  right: 30rpx;
  top: 10rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 193, 7, 0.7);
  color: rgba(255, 193, 7, 0.7);
  font-weight: 700;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-12deg) scale(0.6);
  opacity: 0;
  animation: stamp 0.6s ease-out forwards;
  background: radial-gradient(circle at 30% 30%, rgba(255, 251, 230, 0.9), rgba(255, 255, 255, 0.2));
}

.stamp::after {
  content: "已盖章";
}

@keyframes stamp {
  0% {
    transform: translateY(-40rpx) rotate(-12deg) scale(0.2);
    opacity: 0;
  }
  60% {
    transform: translateY(0) rotate(-12deg) scale(1.1);
    opacity: 1;
  }
  100% {
    transform: translateY(0) rotate(-12deg) scale(1);
    opacity: 1;
  }
}
