.detail-title {
  font-weight: 700;
  font-size: 32rpx;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.section-title {
  font-weight: 700;
  margin-bottom: 12rpx;
  color: #4a2f1d;
}

.parchment-card {
  background: linear-gradient(180deg, rgba(255, 251, 240, 0.98), rgba(245, 228, 198, 0.98));
  border: 1rpx solid rgba(125, 88, 49, 0.25);
}

.wax-btn {
  background: radial-gradient(circle at 30% 30%, #d8473b, #9b2d24 70%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 10rpx 20rpx rgba(155, 45, 36, 0.35), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
}

.wax-btn::after {
  border: none;
}

.stamp-area {
  position: relative;
  height: 120rpx;
  margin: 8rpx 0 16rpx;
}

.stamp {
  position: absolute;
  right: 30rpx;
  top: 10rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(189, 41, 36, 0.9);
  color: rgba(189, 41, 36, 0.9);
  font-weight: 700;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transform: rotate(-12deg) scale(0.6);
  opacity: 0;
  animation: stamp 0.6s ease-out forwards;
  background: radial-gradient(circle at 30% 30%, rgba(255, 244, 244, 0.8), rgba(255, 255, 255, 0.2));
}

.stamp::after {
  content: "已盖章";
}

@keyframes stamp {
  0% {
    transform: translateY(-40rpx) rotate(-12deg) scale(0.2);
    opacity: 0;
  }
  60% {
    transform: translateY(0) rotate(-12deg) scale(1.1);
    opacity: 1;
  }
  100% {
    transform: translateY(0) rotate(-12deg) scale(1);
    opacity: 1;
  }
}

