.contract-page {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
}

.header-button-wrapper {
  background: linear-gradient(to right, #FFD700, #FFA500);
  border-radius: 40rpx;
  padding: 2rpx;
}

.create-contract-btn {
  background: transparent;
  color: #fff;
  font-size: 28rpx;
  padding: 10rpx 25rpx;
  border-radius: 40rpx;
  margin: 0;
  line-height: 1;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.create-contract-btn::after {
  border: none;
}

.plus-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
  font-weight: bold;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  margin: 20rpx 30rpx;
  padding: 15rpx 20rpx;
  border-radius: 10rpx;
}

.search-icon {
  margin-right: 15rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-placeholder {
  color: #ccc;
}

.tab-bar {
  white-space: nowrap;
  padding: 20rpx 0;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.tab-item {
  display: inline-block;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #333;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  display: block;
  width: 50%;
  height: 6rpx;
  background-color: #FFD700;
  position: absolute;
  bottom: -10rpx;
  left: 25%;
  border-radius: 3rpx;
}

.contract-list {
  padding: 0 30rpx;
  padding-bottom: 120rpx;
}

.contract-card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-header-right {
  text-align: right;
}

.status-tag {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  color: #666;
}

.contract-id {
  font-size: 24rpx;
  color: #999;
}

.deposit-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.deposit-amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #000;
}

.card-body {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 20rpx;
}

.contract-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.footer-info {
  display: flex;
  align-items: center;
}

.footer-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.detail-link {
  color: #FFD700;
  font-size: 28rpx;
}
