.contract-page {
  background-color: var(--color-background);
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--color-foreground);
  letter-spacing: -1rpx;
}

.create-contract-btn {
  background: #fcc419;
  color: #212529;
  font-size: 24rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  margin: 0;
  line-height: 1.2;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 30rpx rgba(252, 196, 25, 0.2);
}

.create-contract-btn::after {
  border: none;
}

.plus-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #212529;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 900;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f1f3f5;
  margin: 18rpx 32rpx 12rpx;
  padding: 18rpx 24rpx;
  border-radius: 32rpx;
}

.search-icon {
  margin-right: 16rpx;
  color: var(--color-muted-foreground);
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-foreground);
}

.search-placeholder {
  color: rgba(142, 154, 175, 0.7);
}

.tab-bar {
  white-space: nowrap;
  padding: 12rpx 0 10rpx;
  margin: 0 0 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
}

.tab-item {
  display: inline-flex;
  padding: 0 28rpx 16rpx;
  font-size: 26rpx;
  color: var(--color-muted-foreground);
  position: relative;
  font-weight: 700;
}

.tab-item.active {
  color: var(--color-foreground);
}

.tab-underline {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 0;
  height: 8rpx;
  background-color: #fcc419;
  border-radius: 999rpx;
}

.contract-list {
  padding: 0 32rpx 120rpx;
}

.contract-card {
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.status-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  background: #f1f3f5;
  color: #8e9aaf;
  border: 1rpx solid transparent;
  font-weight: 700;
}

.credit-tag {
  padding: 4rpx 10rpx;
  border-radius: 14rpx;
  background: #fff9db;
  color: #d9a42b;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
}

.credit-label {
  font-size: 18rpx;
  font-weight: 900;
}

.contract-id {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.6);
  font-weight: 700;
}

.deposit-label {
  font-size: 22rpx;
  color: var(--color-muted-foreground);
  font-weight: 600;
}

.card-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0 18rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  margin-bottom: 12rpx;
}

.contract-title {
  font-size: 30rpx;
  font-weight: 800;
  color: rgba(26, 26, 30, 0.9);
  flex: 1;
}

.contract-title .opponent {
  color: var(--color-foreground);
  font-weight: 900;
}

.deposit-amount {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--color-foreground);
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-muted-foreground);
}

.footer-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.footer-icon {
  font-size: 24rpx;
  color: rgba(142, 154, 175, 0.6);
}

.detail-link {
  color: #fcc419;
  font-size: 24rpx;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.detail-arrow {
  font-size: 30rpx;
  line-height: 1;
}

.status-ACTIVE,
.status-IN_GAME {
  background: #fff9db;
  color: #d9a42b;
  border-color: rgba(217, 164, 43, 0.2);
}

.status-PENDING,
.status-PAID {
  background: #e9f2ff;
  color: #339af0;
  border-color: #cfe0ff;
}

.status-DISPUTE,
.status-VIOLATED {
  background: #fff5f5;
  color: #fa5252;
  border-color: #ffd0d0;
}

.status-COMPLETED,
.status-CANCELLED {
  background: #f1f3f5;
  color: #868e96;
  border-color: #e6e8ec;
}
