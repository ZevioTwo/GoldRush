.contract-page {
  overflow: hidden;
}

.home-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 26rpx;
  position: relative;
  z-index: 1;
}

.header-title {
  font-size: 48rpx;
  font-weight: 900;
  color: var(--color-foreground);
  letter-spacing: -1rpx;
  line-height: 1.1;
  display: block;
}

.header-subtitle {
  display: block;
  margin-top: 10rpx;
  color: rgba(142, 154, 175, 0.85);
  font-size: 23rpx;
  font-weight: 700;
}

.create-contract-btn {
  background: linear-gradient(135deg, #f1c74f 0%, #fcc419 100%);
  color: #212529;
  font-size: 24rpx;
  padding: 16rpx 28rpx;
  border-radius: 999rpx;
  margin: 0;
  line-height: 1.2;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 30rpx rgba(252, 196, 25, 0.2);
}

.create-contract-btn::after {
  border: none;
}

.plus-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #212529;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 900;
}

.search-bar {
  display: flex;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 18rpx 24rpx;
  border-radius: 32rpx;
  position: relative;
  z-index: 1;
}

.search-icon {
  margin-right: 16rpx;
  color: var(--color-muted-foreground);
  font-size: 34rpx;
  font-weight: 700;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-foreground);
}

.search-placeholder {
  color: rgba(142, 154, 175, 0.7);
}

.tab-bar {
  white-space: nowrap;
  padding: 12rpx 0 10rpx;
  margin: 0 0 20rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  position: relative;
  z-index: 1;
}

.tab-item {
  display: inline-flex;
  padding: 0 28rpx 18rpx;
  font-size: 26rpx;
  color: var(--color-muted-foreground);
  position: relative;
  font-weight: 800;
}

.tab-item.active {
  color: var(--color-foreground);
}

.tab-underline {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 0;
  height: 8rpx;
  background-color: #fcc419;
  border-radius: 999rpx;
}

.contract-list {
  padding-bottom: 20rpx;
  position: relative;
  z-index: 1;
}

.contract-card {
  border-radius: 32rpx;
  padding: 28rpx 28rpx 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.status-tag {
  font-size: 20rpx;
  padding: 5rpx 14rpx;
  border-radius: 16rpx;
  background: #f1f3f5;
  color: #8e9aaf;
  border: 1rpx solid transparent;
  font-weight: 800;
}

.credit-tag {
  padding: 4rpx 10rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
}

.credit-label {
  font-size: 18rpx;
  font-weight: 900;
}

.contract-id {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.6);
  font-weight: 700;
}

.deposit-label {
  font-size: 22rpx;
  color: rgba(142, 154, 175, 0.8);
  font-weight: 700;
}

.card-body {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0 18rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.03);
  margin-bottom: 14rpx;
}

.contract-title {
  font-size: 32rpx;
  font-weight: 800;
  color: rgba(26, 26, 30, 0.9);
  flex: 1;
  line-height: 1.3;
}

.contract-title .opponent {
  color: var(--color-foreground);
  font-weight: 900;
}

.deposit-amount {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--color-foreground);
  line-height: 1.2;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-muted-foreground);
}

.footer-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.footer-icon {
  font-size: 22rpx;
  color: #d9a42b;
}

.detail-link {
  color: #fcc419;
  font-size: 24rpx;
  font-weight: 800;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.detail-arrow {
  font-size: 30rpx;
  line-height: 1;
}

.status-warning {
  background: #fff9db;
  color: #d9a42b;
  border-color: rgba(217, 164, 43, 0.2);
}

.status-info {
  background: #e9f2ff;
  color: #339af0;
  border-color: #cfe0ff;
}

.status-danger {
  background: #fff5f5;
  color: #fa5252;
  border-color: #ffd0d0;
}

.status-neutral {
  background: #f1f3f5;
  color: #868e96;
  border-color: #e6e8ec;
}

.credit-tag.credit-special,
.credit-tag.credit-high {
  background: #fff9db;
  color: #d9a42b;
}

.credit-tag.credit-low {
  background: #e9f2ff;
  color: #339af0;
  border-color: rgba(51, 154, 240, 0.18);
}

.credit-tag.credit-none {
  background: #f1f3f5;
  color: #868e96;
  border-color: rgba(134, 142, 150, 0.15);
}

.loading-state,
.list-end {
  text-align: center;
  color: rgba(142, 154, 175, 0.82);
  font-size: 22rpx;
  font-weight: 700;
  padding: 24rpx 0;
}
