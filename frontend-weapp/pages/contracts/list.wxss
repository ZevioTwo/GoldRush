.list-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.list-header-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.parchment-card {
  background: linear-gradient(180deg, rgba(255, 251, 240, 0.98), rgba(245, 228, 198, 0.98));
  border: 1rpx solid rgba(125, 88, 49, 0.25);
}

.wax-btn {
  background: radial-gradient(circle at 30% 30%, #d8473b, #9b2d24 70%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 10rpx 20rpx rgba(155, 45, 36, 0.35), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
}

.wax-btn::after {
  border: none;
}
