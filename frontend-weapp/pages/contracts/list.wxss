.list-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.parchment-card {
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
}

.wax-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28);
}

.wax-btn::after {
  border: none;
}

.contract-card {
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.contract-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.contract-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.contract-amount {
  font-size: 30rpx;
  font-weight: 700;
  color: #2563eb;
}
