.contract-page {
  background-color: #ffffff;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
  background-color: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.header-button-wrapper {
  background: #ffc400;
  border-radius: 999rpx;
  padding: 0;
}

.create-contract-btn {
  background: #ffc400;
  color: #1f1f1f;
  font-size: 26rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  margin: 0;
  line-height: 1.2;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-weight: 600;
}

.create-contract-btn::after {
  border: none;
}

.plus-icon {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid #1f1f1f;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  line-height: 1;
  margin-right: 4rpx;
  font-weight: 700;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #f4f6f9;
  margin: 18rpx 24rpx 8rpx;
  padding: 18rpx 22rpx;
  border-radius: 32rpx;
}

.search-icon {
  margin-right: 12rpx;
  color: #9aa1ac;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #2a2f36;
}

.search-placeholder {
  color: #b8bfc9;
}

.tab-bar {
  white-space: nowrap;
  padding: 8rpx 0 10rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f1f3;
  margin-bottom: 8rpx;
}

.tab-item {
  display: inline-block;
  padding: 0 24rpx 12rpx;
  font-size: 26rpx;
  color: #9aa1ac;
  position: relative;
}

.tab-item.active {
  color: #20242a;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  display: block;
  width: 44rpx;
  height: 6rpx;
  background-color: #ffc400;
  position: absolute;
  bottom: 0;
  left: 24rpx;
  border-radius: 999rpx;
}

.contract-list {
  padding: 0 24rpx 120rpx;
}

.contract-card {
  background-color: #f6f7f9;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: none;
  border: none;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-header-right {
  text-align: right;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  background: #f0f2f5;
  color: #7a808a;
  border: 1rpx solid transparent;
}

.contract-id {
  font-size: 22rpx;
  color: #9aa1ac;
}

.deposit-label {
  font-size: 22rpx;
  color: #a0a6b0;
  display: block;
}

.deposit-amount {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.card-body {
  padding: 10rpx 0 12rpx;
  border-bottom: 1rpx solid #e9edf2;
  margin-bottom: 10rpx;
}

.contract-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #8b919b;
}

.footer-info {
  display: flex;
  align-items: center;
}

.footer-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
  color: #9aa1ac;
}

.detail-link {
  color: #ffb100;
  font-size: 24rpx;
  font-weight: 600;
}

.status-ACTIVE,
.status-IN_GAME {
  background: #fff4cc;
  color: #c68400;
  border-color: #ffe2a1;
}

.status-PENDING,
.status-PAID {
  background: #e9f2ff;
  color: #4a78ff;
  border-color: #cfe0ff;
}

.status-DISPUTE,
.status-VIOLATED {
  background: #ffe9e9;
  color: #e05c5c;
  border-color: #ffd0d0;
}

.status-COMPLETED,
.status-CANCELLED {
  background: #f1f2f4;
  color: #9aa1ac;
  border-color: #e6e8ec;
}
