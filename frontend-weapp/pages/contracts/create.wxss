.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.textarea,
.picker,
.readonly {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  box-shadow: inset 0 1rpx 2rpx rgba(16, 24, 40, 0.05);
}

.parchment-input {
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  box-shadow: inset 0 1rpx 2rpx rgba(16, 24, 40, 0.05);
}

.readonly {
  color: #1f2329;
}

.textarea {
  min-height: 160rpx;
}

.wax-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28);
}

.wax-btn::after {
  border: none;
}
