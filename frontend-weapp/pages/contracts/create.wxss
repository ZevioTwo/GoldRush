.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #5e6572;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.textarea,
.picker,
.readonly {
  background: #f3f4f6;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.readonly {
  color: #1f2329;
}

.textarea {
  min-height: 160rpx;
}
