.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #7a5a41;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.textarea,
.picker,
.readonly {
  background: #f3f4f6;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.parchment-input {
  background: rgba(255, 252, 246, 0.9);
  border: 1rpx solid rgba(138, 96, 57, 0.3);
  box-shadow: inset 0 2rpx 6rpx rgba(122, 90, 65, 0.12);
}

.readonly {
  color: #1f2329;
}

.textarea {
  min-height: 160rpx;
}

.wax-btn {
  background: radial-gradient(circle at 30% 30%, #d8473b, #9b2d24 70%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 10rpx 20rpx rgba(155, 45, 36, 0.35), inset 0 2rpx 6rpx rgba(255, 255, 255, 0.25);
}

.wax-btn::after {
  border: none;
}
