.create-page {
  background-color: transparent;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #ffffff;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  font-size: 36rpx;
  color: #212529;
}

.header-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #212529;
}

.header-spacer {
  width: 64rpx;
}

.form-group {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.04);
}

.form-group.inner {
  background: #f8f9fa;
  border: 1rpx solid #e9ecef;
  margin-top: 16rpx;
}

.group-title {
  font-size: 26rpx;
  font-weight: 900;
  display: block;
  margin-bottom: 16rpx;
  color: #212529;
}

.input-field {
  background-color: #f8f9fa;
  border-radius: 20rpx;
  padding: 0 20rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: 1rpx solid #e9ecef;
}

.textarea-field {
  background-color: #f8f9fa;
  border-radius: 20rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  height: 200rpx;
  border: 1rpx solid #e9ecef;
}

.textarea-field.short {
  height: 160rpx;
}

.dropdown {
  position: relative;
}

.dropdown-trigger {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #e9ecef;
}

.dropdown-trigger.active {
  background: #fff;
  border-color: #d9a42b;
}

.dropdown-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #212529;
}

.dropdown-arrow {
  font-size: 28rpx;
  color: #adb5bd;
  transition: transform 0.3s ease;
}

.dropdown-arrow.open {
  transform: rotate(180deg);
  color: #d9a42b;
}

.dropdown-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 98rpx;
  background: #fff;
  border: 1rpx solid #e9ecef;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.08);
  overflow: hidden;
  z-index: 10;
}

.dropdown-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-bottom: 1rpx solid #f1f3f5;
}

.dropdown-search .search-input {
  flex: 1;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
}

.dropdown-list {
  max-height: 360rpx;
}

.dropdown-item {
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #495057;
}

.dropdown-item.active {
  background: #fff9db;
  color: #d9a42b;
  font-weight: 900;
}

.check-icon {
  font-weight: 900;
}

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.toggle-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toggle-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 20rpx;
  background: #fff9db;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #d9a42b;
  font-size: 28rpx;
}

.toggle-desc {
  font-size: 22rpx;
  color: #868e96;
}

.input-with-unit {
  position: relative;
}

.unit {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #adb5bd;
  font-weight: 800;
}

.reminder-box {
  background-color: #fff9db;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #d9a42b;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.2);
}

.reminder-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  font-weight: 900;
  font-size: 30rpx;
  border-radius: 24rpx;
  padding: 20rpx 0;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
}

.submit-btn::after {
  border: none;
}
