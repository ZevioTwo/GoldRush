<view class="contract-page">
  <view class="header">
    <text class="header-title">我的契约</text>
    <button class="create-contract-btn" bindtap="goCreate">
      <text class="plus-icon">+</text>
      <text>发起契约</text>
    </button>
  </view>

  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索契约ID或对手昵称" placeholder-class="search-placeholder" />
  </view>

  <scroll-view scroll-x="true" class="tab-bar no-scrollbar">
    <view
      wx:for="{{statusOptions}}"
      wx:key="index"
      class="tab-item {{statusIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onStatusTabChange"
    >
      {{item}}
      <view wx:if="{{statusIndex === index}}" class="tab-underline"></view>
    </view>
  </scroll-view>

  <view class="contract-list">
    <block wx:for="{{list}}" wx:key="contractId">
      <view class="contract-card" bindtap="goDetail" data-id="{{item.contractId}}">
        <view class="card-header">
          <view class="card-header-left">
            <text class="status-tag status-{{item.status}}">{{item.statusLabel || item.status}}</text>
            <view class="credit-tag">
              <text class="credit-label">高保户</text>
            </view>
            <text class="contract-id">ID: {{item.contractNo}}</text>
          </view>
          <text class="deposit-label">押信誉分</text>
        </view>

        <view class="card-body">
          <text class="contract-title">与 <text class="opponent">{{item.displayName}}</text> 的契约</text>
          <text class="deposit-amount">{{item.depositAmount}} 信誉分</text>
        </view>

        <view class="card-footer">
          <view class="footer-info">
            <text class="footer-icon">⏱</text>
            <text>剩余时间: {{item.remainingTime || '12:45:30'}}</text>
          </view>
          <view class="detail-link">
            查看详情
            <text class="detail-arrow">›</text>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{list.length === 0}}" class="empty-state" style="margin-top: 48rpx;">
      暂无相关契约记录
    </view>

    <view wx:if="{{loading}}" class="loading-state" style="margin: 24rpx 0;">
      加载中...
    </view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="empty-state" style="margin: 24rpx 0;">
      没有更多了
    </view>
  </view>
</view>
