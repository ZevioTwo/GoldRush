<view class="contract-page page-shell">
  <view class="page-orb page-orb--gold"></view>
  <view class="page-orb page-orb--soft"></view>

  <view class="home-header">
    <view>
      <text class="header-title">我的契约</text>
      <text class="header-subtitle">管理进行中、待生效和仲裁中的契约</text>
    </view>
    <button class="create-contract-btn" bindtap="goCreate">
      <text class="plus-icon">＋</text>
      <text>发起契约</text>
    </button>
  </view>

  <view class="search-bar soft-panel">
    <text class="search-icon">⌕</text>
    <input
      class="search-input"
      value="{{keyword}}"
      bindinput="onKeywordInput"
      bindconfirm="onKeywordConfirm"
      placeholder="搜索契约ID或对手昵称"
      placeholder-class="search-placeholder"
      confirm-type="search"
    />
  </view>

  <scroll-view scroll-x="true" class="tab-bar no-scrollbar">
    <view
      wx:for="{{statusTabs}}"
      wx:key="index"
      class="tab-item {{statusIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onStatusTabChange"
    >
      <text>{{item}}</text>
      <view wx:if="{{statusIndex === index}}" class="tab-underline"></view>
    </view>
  </scroll-view>

  <view class="contract-list">
    <block wx:for="{{list}}" wx:key="contractId">
      <view class="contract-card floating-card" bindtap="goDetail" data-id="{{item.contractId}}">
        <view class="card-header">
          <view class="card-header-left">
            <text class="status-tag {{item.statusClass}}">{{item.statusLabel}}</text>
            <view class="credit-tag {{item.creditClass}}">
              <text class="credit-label">{{item.creditTag}}</text>
            </view>
            <text class="contract-id">ID: {{item.contractNo}}</text>
          </view>
          <text class="deposit-label">押信誉分</text>
        </view>

        <view class="card-body">
          <text class="contract-title">与 <text class="opponent">{{item.displayName}}</text> 的契约</text>
          <text class="deposit-amount">{{item.depositAmount}} 信誉分</text>
        </view>

        <view class="card-footer">
          <view class="footer-info">
            <text class="footer-icon">{{item.footerIcon}}</text>
            <text>{{item.footerLabel}}</text>
          </view>
          <view class="detail-link">
            查看详情
            <text class="detail-arrow">›</text>
          </view>
        </view>
      </view>
    </block>

    <view wx:if="{{list.length === 0 && !loading}}" class="empty-card">
      暂无相关契约记录
    </view>

    <view wx:if="{{loading}}" class="loading-state">
      加载中...
    </view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="list-end">
      没有更多了
    </view>
  </view>
</view>
