<view class="container contract-page">
  <view class="header">
    <text class="header-title">我的契约</text>
    <view class="header-button-wrapper">
      <button class="create-contract-btn" bindtap="goCreate">
        <text class="plus-icon">+</text>发起契约
      </button>
    </view>
  </view>

  <view class="search-bar">
    <icon type="search" size="16" class="search-icon"></icon>
    <input class="search-input" placeholder="搜索契约编号或对方昵称" placeholder-class="search-placeholder" />
  </view>

  <scroll-view scroll-x="true" class="tab-bar">
    <view
      wx:for="{{statusOptions}}"
      wx:key="index"
      class="tab-item {{statusIndex === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onStatusTabChange"
    >
      {{item}}
    </view>
  </scroll-view>

  <view class="contract-list">
    <block wx:for="{{list}}" wx:key="contractId">
      <view class="contract-card" bindtap="goDetail" data-id="{{item.contractId}}">
        <view class="card-header">
          <view class="card-header-left">
            <text class="status-tag status-{{item.status}}">{{item.statusLabel || item.status}}</text>
            <text class="contract-id">#{{item.contractNo}}</text>
          </view>
          <view class="card-header-right">
            <text class="deposit-label">保证金</text>
            <text class="deposit-amount">{{item.depositAmount}}</text>
          </view>
        </view>

        <view class="card-body">
          <text class="contract-title">与 {{item.displayName}} 的契约</text>
        </view>

        <view class="card-footer">
          <view class="footer-info">
            <text class="footer-icon">⏱</text>
            <text>创建时间: {{item.createTime}}</text>
          </view>
          <text class="detail-link">查看详情 ></text>
        </view>
      </view>
    </block>

    <view wx:if="{{list.length === 0}}" class="empty-state" style="margin-top: 48rpx;">
      暂无数据
    </view>

    <view wx:if="{{loading}}" class="loading-state" style="margin: 24rpx 0;">
      加载中...
    </view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="empty-state" style="margin: 24rpx 0;">
      没有更多了
    </view>
  </view>
</view>
