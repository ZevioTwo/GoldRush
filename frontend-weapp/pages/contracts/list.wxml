<view class="container list-page paper-page">
  <view class="paper-card parchment-card">
    <view class="toolbar">
      <view class="toolbar-actions">
        <button class="btn-primary wax-btn" bindtap="goCreate">创建契约</button>
      </view>
      <view class="toolbar-actions">
        <text class="toolbar-label">状态</text>
        <picker mode="selector" range="{{statusOptions}}" bindchange="onStatusChange">
          <view class="toolbar-picker">
            <text class="paper-label">{{statusOptions[statusIndex]}}</text>
          </view>
        </picker>
      </view>
    </view>
  </view>

  <block wx:for="{{list}}" wx:key="contractId">
    <view class="paper-card parchment-card contract-card" bindtap="goDetail" data-id="{{item.contractId}}">
      <view class="contract-title">契约号：{{item.contractNo}}</view>
      <view class="paper-divider"></view>
      <view class="contract-row">
        <text class="text-muted paper-label">状态</text>
        <text class="status-badge">{{item.statusLabel || item.status}}</text>
      </view>
      <view class="contract-row">
        <text class="text-muted paper-label">金额</text>
        <text class="contract-amount">{{item.depositAmount}}</text>
      </view>
      <view class="contract-row">
        <text class="text-muted paper-label">创建时间</text>
        <text class="paper-subtle">{{item.createTime}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{list.length === 0}}" class="empty-state" style="margin-top: 48rpx;">
    暂无数据
  </view>

  <view wx:if="{{loading}}" class="loading-state" style="margin: 24rpx 0;">
    加载中...
  </view>
  <view wx:if="{{!hasMore && list.length > 0}}" class="empty-state" style="margin: 24rpx 0;">
    没有更多了
  </view>
</view>
