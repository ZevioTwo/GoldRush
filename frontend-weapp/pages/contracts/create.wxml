<view class="container">
  <view class="form-group">
    <text class="group-title">契约标题</text>
    <input class="input-field" placeholder="请输入契约标题, 如: 诚信借贷协议" value="{{form.title}}" data-field="title" bindinput="onInput" />
  </view>

  <view class="form-group">
    <text class="group-title">是否需要保证金</text>
    <picker mode="selector" range="{{depositRequiredOptions}}" bindchange="onDepositRequiredChange">
      <view class="input-field picker-field">
        {{depositRequiredOptions[depositRequiredIndex]}}
      </view>
    </picker>
  </view>

  <view class="form-group" wx:if="{{depositRequiredIndex === 0}}">
    <text class="group-title">保证金（0.1-648）</text>
    <input class="input-field" type="digit" placeholder="100" value="{{form.depositAmount}}" data-field="depositAmount" bindinput="onInput" />
  </view>

  <view class="form-group">
    <text class="group-title">契约达成条件</text>
    <textarea class="textarea-field" placeholder="请详细描述契约内容及双方约定的具体条款内容..." value="{{form.successCondition}}" data-field="successCondition" bindinput="onInput"></textarea>
  </view>

  <view class="reminder-box">
    <text class="reminder-icon">⚠️</text>
    <text class="reminder-text">温馨提示: 契约一经发起并达成, 将具有法律效力并计入摸金信誉档案, 请谨慎填写条款内容。</text>
  </view>

  <button class="submit-btn" bindtap="submit" loading="{{loading}}">确认发起契约</button>
</view>
