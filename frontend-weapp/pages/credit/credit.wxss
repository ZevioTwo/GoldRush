.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.credit-label {
  font-size: 28rpx;
  color: #666;
}

.shield-icon {
  font-size: 36rpx;
  color: #FFC107;
}

.credit-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 0.6rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.credit-progress {
  margin-bottom: 10rpx;
}

.recharge-card {
  padding: 28rpx 30rpx 34rpx;
}

.recharge-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1f1f;
  margin-bottom: 8rpx;
}

.recharge-desc {
  font-size: 24rpx;
  color: #9aa1ac;
  margin-bottom: 20rpx;
}

.amount-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #f6f7f9;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 22rpx;
}

.amount-label {
  font-size: 26rpx;
  color: #5a6069;
}

.amount-input {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #1f1f1f;
}

.recharge-btn {
  background-color: #FFC107;
  color: #fff;
  font-weight: 700;
  font-size: 30rpx;
  border-radius: 14rpx;
  padding: 18rpx 0;
}

.recharge-btn::after {
  border: none;
}
