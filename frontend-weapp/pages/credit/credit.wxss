.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.credit-label {
  font-size: 28rpx;
  color: #666;
}

.shield-icon {
  font-size: 36rpx;
  color: #FFC107;
}

.credit-score {
  font-size: 72rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 0.6rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.credit-progress {
  margin-bottom: 10rpx;
}

.info-card .row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-card .row:last-child {
  border-bottom: none;
}

.text-muted {
  color: #999;
}
