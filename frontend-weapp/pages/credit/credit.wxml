<view class="container">
  <view class="card" style="text-align: center;">
    <view class="text-muted" style="margin-bottom: 16rpx;">当前信用分</view>
    <view class="credit-score">{{creditScore}}</view>
  </view>

  <view class="card">
    <view class="row">
      <text class="text-muted">用户ID</text>
      <text>{{profile.userId}}</text>
    </view>
    <view class="row">
      <text class="text-muted">昵称</text>
      <text>{{profile.nickname}}</text>
    </view>
    <view class="row">
      <text class="text-muted">最近更新</text>
      <text>{{profile.updatedAt || '-'}}</text>
    </view>
  </view>
</view>
