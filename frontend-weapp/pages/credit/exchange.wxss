.exchange-page {
  overflow: hidden;
}

.info-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.03);
  margin-bottom: 24rpx;
  position: relative;
  overflow: hidden;
}

.info-card::after {
  content: "";
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 200rpx;
  height: 200rpx;
  background: #fff9db;
  border-radius: 50%;
  opacity: 0.6;
}

.info-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.info-icon-box {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: #fcf8e8;
  color: #d9a42b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
}

.info-label {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.6);
  font-weight: 900;
  letter-spacing: 2rpx;
}

.info-score-row {
  display: flex;
  align-items: flex-end;
  gap: 10rpx;
}

.info-score {
  font-size: 42rpx;
  font-weight: 900;
  color: var(--color-foreground);
  line-height: 1;
}

.info-score-unit {
  font-size: 22rpx;
  margin-bottom: 4rpx;
  color: rgba(142, 154, 175, 0.7);
}

.wallet-meta {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.wallet-meta-item {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
}

.wallet-meta-label {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.8);
  margin-bottom: 6rpx;
}

.wallet-meta-value {
  font-size: 24rpx;
  font-weight: 900;
  color: #212529;
}

.info-desc {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.7);
  line-height: 1.6;
  position: relative;
  z-index: 1;
}

.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
}

.section-icon {
  color: #d9a42b;
}

.preset-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.preset-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(0, 0, 0, 0.03);
  position: relative;
  text-align: center;
}

.preset-card.active {
  border-color: #d9a42b;
  background: rgba(252, 248, 232, 0.3);
  box-shadow: 0 12rpx 28rpx rgba(217, 164, 43, 0.12);
}

.preset-card.disabled {
  opacity: 0.55;
}

.preset-badge {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #d9a42b;
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 999rpx;
  font-weight: 900;
}

.preset-label {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.7);
  font-weight: 800;
}

.preset-points {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
  margin: 8rpx 0;
}

.preset-value {
  font-size: 38rpx;
  font-weight: 900;
  color: var(--color-foreground);
  line-height: 1;
}

.preset-unit {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.6);
  margin-bottom: 4rpx;
}

.exchange-text {
  display: block;
  font-size: 22rpx;
  font-weight: 900;
  color: #d9a42b;
}

.preset-bonus {
  font-size: 18rpx;
  color: #d9a42b;
  background: #fff;
  border-radius: 999rpx;
  padding: 4rpx 10rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.2);
  display: inline-block;
  margin-top: 8rpx;
}

.warning {
  background: rgba(250, 82, 82, 0.05);
  border: 1rpx solid rgba(250, 82, 82, 0.1);
  padding: 16rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.warning-text {
  font-size: 20rpx;
  color: #fa5252;
  line-height: 1.6;
}

.pay-btn {
  width: 100%;
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  border-radius: 28rpx;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
}

.pay-btn::after {
  border: none;
}
