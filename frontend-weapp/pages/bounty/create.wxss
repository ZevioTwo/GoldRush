.create-page {
  background-color: transparent;
}

.summary-card {
  background: linear-gradient(135deg, rgba(252, 248, 232, 0.94) 0%, #ffffff 100%);
  border-radius: 30rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.18);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.04);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.summary-label {
  display: block;
  font-size: 20rpx;
  color: rgba(122, 106, 54, 0.9);
  margin-bottom: 8rpx;
}

.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: #d9a42b;
  line-height: 1;
}

.summary-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
}

.summary-pill.ok {
  background: rgba(34, 197, 94, 0.14);
  color: #22c55e;
}

.summary-pill.warn {
  background: rgba(250, 82, 82, 0.14);
  color: #fa5252;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.summary-item {
  background: rgba(255, 255, 255, 0.82);
  border-radius: 22rpx;
  padding: 18rpx 16rpx;
}

.summary-item-label {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.9);
  margin-bottom: 8rpx;
}

.summary-item-value {
  display: block;
  font-size: 28rpx;
  font-weight: 900;
  color: #212529;
}

.summary-item-value.accent {
  color: #d9a42b;
}

.form-group {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.04);
}

.reward-note-card {
  background: linear-gradient(135deg, rgba(252, 248, 232, 0.92) 0%, rgba(255, 255, 255, 0.98) 100%);
  border-radius: 28rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.18);
  margin-bottom: 24rpx;
}

.reward-note-title {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
  color: #d9a42b;
  margin-bottom: 10rpx;
}

.reward-note-desc {
  font-size: 22rpx;
  color: #7a6a36;
  line-height: 1.7;
}

.group-title {
  font-size: 26rpx;
  font-weight: 900;
  display: block;
  margin-bottom: 16rpx;
  color: #212529;
}

.input-field {
  background-color: #f8f9fa;
  border-radius: 20rpx;
  padding: 0 20rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  height: 88rpx;
  line-height: 88rpx;
  border: 1rpx solid #e9ecef;
}

.textarea-field {
  background-color: #f8f9fa;
  border-radius: 20rpx;
  padding: 20rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: 26rpx;
  height: 220rpx;
  border: 1rpx solid #e9ecef;
}

.dropdown {
  position: relative;
}

.dropdown-trigger {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 0 20rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1rpx solid #e9ecef;
}

.dropdown-trigger.active {
  background: #fff;
  border-color: #d9a42b;
}

.dropdown-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #212529;
}

.dropdown-arrow {
  font-size: 28rpx;
  color: #adb5bd;
  transition: transform 0.3s ease;
}

.dropdown-arrow.open {
  transform: rotate(180deg);
  color: #d9a42b;
}

.dropdown-panel {
  position: absolute;
  left: 0;
  right: 0;
  top: 98rpx;
  background: #fff;
  border: 1rpx solid #e9ecef;
  border-radius: 20rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  z-index: 10;
}

.dropdown-search {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-bottom: 1rpx solid #f1f3f5;
}

.dropdown-search .search-input {
  flex: 1;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
}

.dropdown-list {
  max-height: 360rpx;
}

.dropdown-item {
  padding: 16rpx 20rpx;
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #495057;
}

.dropdown-item.active {
  background: #fff9db;
  color: #d9a42b;
  font-weight: 900;
}

.check-icon {
  font-weight: 900;
}

.input-with-unit {
  position: relative;
}

.unit {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 22rpx;
  color: #adb5bd;
  font-weight: 800;
}

.reminder-box {
  background-color: #fff9db;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #d9a42b;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.2);
}

.reminder-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.submit-btn {
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  font-weight: 900;
  font-size: 30rpx;
  border-radius: 24rpx;
  padding: 20rpx 0;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
}

.submit-btn::after {
  border: none;
}
