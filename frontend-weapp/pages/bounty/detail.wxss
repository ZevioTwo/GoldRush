.bounty-detail-page {
  position: relative;
  overflow: hidden;
}

.hero-card,
.detail-section {
  position: relative;
  z-index: 1;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.hero-title-wrap {
  flex: 1;
}

.hero-title {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #1f2933;
  line-height: 1.4;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(142, 154, 175, 0.92);
}

.status-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  white-space: nowrap;
}

.status-pill.open {
  color: #d9a42b;
  background: rgba(252, 196, 25, 0.14);
}

.status-pill.full {
  color: #8e9aaf;
  background: rgba(142, 154, 175, 0.14);
}

.reward-panel {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fdfaf1 0%, #fff 100%);
  border: 1rpx solid rgba(217, 164, 43, 0.1);
  margin-bottom: 16rpx;
}

.reward-label {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.86);
  margin-bottom: 10rpx;
}

.reward-value-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.reward-value {
  font-size: 42rpx;
  font-weight: 900;
  color: #d9a42b;
  line-height: 1;
}

.reward-unit {
  font-size: 22rpx;
  color: rgba(142, 154, 175, 0.9);
  margin-bottom: 4rpx;
}

.reward-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: center;
  gap: 10rpx;
}

.reward-side-text {
  font-size: 20rpx;
  color: #7a869a;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-item {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f8f9fa;
  color: #6c7a89;
  font-size: 20rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 900;
  color: #1f2933;
}

.section-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(217, 164, 43, 0.12);
  color: #d9a42b;
  font-size: 20rpx;
  font-weight: 900;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.stat-card {
  padding: 20rpx;
  border-radius: 24rpx;
  background: #f8f9fa;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.92);
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 900;
  color: #212529;
}

.progress-track {
  width: 100%;
  height: 14rpx;
  border-radius: 999rpx;
  background: #eef1f4;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
}

.progress-note {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #7a869a;
  line-height: 1.7;
}

.description-text {
  display: block;
  font-size: 24rpx;
  color: #495057;
  line-height: 1.85;
  white-space: pre-wrap;
}

.claim-btn {
  margin-top: 8rpx;
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  font-weight: 900;
  font-size: 30rpx;
  border-radius: 24rpx;
  padding: 20rpx 0;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
  position: relative;
  z-index: 1;
}

.claim-btn.disabled {
  background: #eef1f4;
  color: #9aa5b1;
  box-shadow: none;
}

.claim-btn::after {
  border: none;
}

.loading-state,
.empty-card {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 24rpx;
  color: #8e9aaf;
  padding: 80rpx 0;
}
