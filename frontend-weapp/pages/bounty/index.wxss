.bounty-page {
  position: relative;
  overflow: hidden;
}

.home-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-foreground);
}

.header-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--color-muted-foreground);
}

.create-bounty-btn {
  min-width: 208rpx;
  padding: 0 20rpx;
  height: 84rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.22);
}

.create-bounty-btn::after {
  border: none;
}

.plus-icon {
  font-size: 28rpx;
}

.bounty-list {
  position: relative;
  z-index: 1;
}

.bounty-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(180deg, #fff6e7 0%, #fffaf1 100%);
  border: 1rpx solid rgba(217, 164, 43, 0.14);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.06);
}

.bounty-card--active {
  transform: scale(0.992);
  opacity: 0.96;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.title-wrap {
  flex: 1;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #1f2933;
  line-height: 1.4;
}

.card-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(142, 154, 175, 0.9);
}

.status-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 900;
  white-space: nowrap;
}

.status-pill.open {
  color: #d9a42b;
  background: rgba(252, 196, 25, 0.14);
}

.status-pill.full {
  color: #8e9aaf;
  background: rgba(142, 154, 175, 0.14);
}

.reward-strip {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #fffaf0 0%, #ffffff 100%);
  border: 1rpx solid rgba(217, 164, 43, 0.12);
  margin-bottom: 18rpx;
}

.reward-label {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.86);
  margin-bottom: 10rpx;
}

.reward-value-row {
  display: flex;
  align-items: flex-end;
  gap: 8rpx;
}

.reward-value {
  font-size: 40rpx;
  font-weight: 900;
  color: #d9a42b;
  line-height: 1;
}

.reward-unit {
  font-size: 22rpx;
  color: rgba(142, 154, 175, 0.86);
  margin-bottom: 4rpx;
}

.reward-side {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-end;
  justify-content: center;
}

.reward-side-text {
  font-size: 20rpx;
  color: #7a869a;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.footer-note-wrap {
  flex: 1;
}

.footer-note {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.9);
}

.footer-link {
  display: inline-block;
  margin-top: 8rpx;
  font-size: 22rpx;
  font-weight: 900;
  color: #d9a42b;
}

.claim-btn {
  min-width: 188rpx;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.claim-btn.disabled {
  background: #eef1f4;
  color: #9aa5b1;
}

.claim-btn::after {
  border: none;
}

.empty-card,
.loading-state,
.list-end {
  text-align: center;
  font-size: 24rpx;
  color: #8e9aaf;
  padding: 28rpx 0;
}
