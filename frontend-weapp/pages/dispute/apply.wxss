.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding: 20rpx 30rpx 140rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.form-card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 15rpx;
}

.picker {
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #999;
}

.picker-arrow {
  color: #ccc;
}

.description-input {
  width: 100%;
  height: 180rpx;
  background-color: #f8f8f8;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.submit-btn {
  background-color: #4CAF50;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 10rpx;
  margin-top: 20rpx;
}

.submit-notice {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
}

.hint,
.text-muted {
  color: #8b929c;
  font-size: 24rpx;
  margin-top: 8rpx;
}
