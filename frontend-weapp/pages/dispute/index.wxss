.container {
  background-color: #f8f8f8;
  padding: 20rpx 30rpx;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
}

.apply-btn {
  background-color: #F44336;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 15rpx 30rpx;
  margin: 0;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.title-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
  color: #FFC107;
}

.history-section {
  margin-bottom: 40rpx;
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-left: 40rpx;
  margin-bottom: 30rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 10rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background-color: #ccc;
}

.timeline-dot.resolved { background-color: #4CAF50; }
.timeline-dot.inProgress { background-color: #FFC107; }

.timeline-item::before {
  content: '';
  position: absolute;
  left: 9rpx;
  top: 30rpx;
  bottom: -30rpx;
  width: 2rpx;
  background-color: #e0e0e0;
}

.timeline-item:last-child::before {
  display: none;
}

.timeline-content {
  flex: 1;
}

.history-card {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.card-row:last-child { margin-bottom: 0; }

.status-tag {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 8rpx;
}

.status-tag.resolved { background-color: #E8F5E9; color: #4CAF50; }
.status-tag.inProgress { background-color: #FFF8E1; color: #FFC107; }

.card-divider {
  height: 1rpx;
  background-color: #f0f0f0;
  margin: 20rpx 0;
}

.result-row .result-label {
  font-weight: bold;
  color: #333;
}

.result-text.resolved { color: #F44336; font-weight: bold; }
.result-text.inProgress { color: #333; }
