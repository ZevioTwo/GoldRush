.dispute-page {
  overflow: hidden;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.header-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #212529;
}

.apply-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #fa5252 100%);
  color: #fff;
  font-size: 24rpx;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
  margin: 0;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(250, 82, 82, 0.2);
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  font-weight: 900;
  margin-bottom: 24rpx;
  color: #212529;
}

.title-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  color: #fcc419;
}

.timeline {
  position: relative;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-left: 40rpx;
  margin-bottom: 24rpx;
}

.timeline-dot {
  position: absolute;
  left: 0;
  top: 18rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #ccc;
  border: 4rpx solid #fff;
}

.timeline-dot.resolved { background-color: #22c55e; }
.timeline-dot.inProgress { background-color: #fcc419; }

.timeline-item::before {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 38rpx;
  bottom: -24rpx;
  width: 2rpx;
  background-color: #f1f3f5;
}

.timeline-item:last-child::before { display: none; }

.history-card {
  background-color: #fff;
  border-radius: 28rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(0,0,0,0.03);
  border: 1rpx solid rgba(0,0,0,0.05);
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.status-tag {
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 800;
}

.status-tag.resolved { background-color: #e7f9ee; color: #22c55e; }
.status-tag.inProgress { background-color: #fff9db; color: #d9a42b; }

.card-divider {
  height: 1rpx;
  background-color: #f1f3f5;
  margin: 16rpx 0;
}

.result-row .result-label {
  font-weight: 900;
  color: #333;
}

.result-text.resolved { color: #fa5252; font-weight: 900; }
.result-text.inProgress { color: #333; }

.new-apply {
  margin-top: 32rpx;
}

.form-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.03);
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  font-weight: 900;
  color: #212529;
  margin-bottom: 12rpx;
}

.picker,
.textarea,
.input {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  font-size: 24rpx;
  color: #212529;
}

.upload-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.upload-item {
  background: #f8f9fa;
  border: 2rpx dashed #e9ecef;
  border-radius: 24rpx;
  padding: 30rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: rgba(142, 154, 175, 0.6);
}

.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #2bd36f 0%, #22c55e 100%);
  color: #fff;
  border-radius: 24rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 900;
  box-shadow: 0 12rpx 30rpx rgba(34, 197, 94, 0.2);
}

.form-tip {
  display: block;
  text-align: center;
  font-size: 18rpx;
  color: rgba(142, 154, 175, 0.6);
  margin-top: 12rpx;
}
