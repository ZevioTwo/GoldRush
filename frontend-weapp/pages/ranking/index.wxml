<view class="container">
  <view class="header">
    <text class="header-title">信誉排行榜</text>
  </view>

  <view class="update-time-card">
    <view>
      <text class="update-label">更新时间</text>
      <text class="update-time">{{updateTime}}</text>
    </view>
    <text class="shield-icon">🛡</text>
  </view>

  <view class="tabs">
    <view class="tab-item {{activeTab === 'red' ? 'active' : ''}}" data-tab="red" bindtap="switchTab">
      <text class="tab-icon">🔥</text> 红榜
    </view>
    <view class="tab-item {{activeTab === 'black' ? 'active' : ''}}" data-tab="black" bindtap="switchTab">
      <text class="tab-icon">⚠️</text> 黑榜
    </view>
  </view>

  <view class="ranking-list-container">
    <view class="ranking-list red-list" hidden="{{activeTab !== 'red'}}">
      <block wx:for="{{redList}}" wx:key="rank">
        <view class="list-item {{item.rank === 1 ? 'top1' : ''}}">
          <view class="rank-number">{{item.rank < 10 ? '0' + item.rank : item.rank}}</view>
          <view class="user-info">
            <text wx:if="{{item.rank === 1}}" class="top1-tag">TOP 1</text>
            <text class="user-name">{{item.name}}</text>
          </view>
          <view class="score yellow-score">{{item.score}}分</view>
        </view>
      </block>
    </view>

    <view class="ranking-list black-list" hidden="{{activeTab !== 'black'}}">
      <block wx:for="{{blackList}}" wx:key="rank">
        <view class="list-item {{item.rank === 1 ? 'bottom1' : ''}}">
          <view class="rank-number">{{item.rank < 10 ? '0' + item.rank : item.rank}}</view>
          <view class="user-info">
            <text wx:if="{{item.rank === 1}}" class="bottom1-tag">垫底 1</text>
            <text class="user-name">{{item.name}}</text>
          </view>
          <view class="score red-score">{{item.score}}分</view>
        </view>
      </block>
    </view>
  </view>
</view>
