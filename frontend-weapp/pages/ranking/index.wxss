.ranking-page {
  overflow: hidden;
}

.header {
  text-align: center;
  margin-bottom: 32rpx;
  position: relative;
}

.header-title {
  font-size: 40rpx;
  font-weight: 900;
  color: #212529;
}

.header-icon {
  position: absolute;
  right: 0;
  top: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: rgba(142, 154, 175, 0.65);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.update-time-card {
  background-color: rgba(255, 249, 219, 0.5);
  border: 1rpx solid rgba(252, 196, 25, 0.1);
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  box-shadow: 0 20rpx 40rpx rgba(252, 196, 25, 0.05);
}

.update-label {
  display: block;
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.6);
  margin-bottom: 6rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.update-time {
  font-size: 30rpx;
  font-weight: 900;
  color: #212529;
}

.shield-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 16rpx;
  background: #fcc419;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 28rpx rgba(252, 196, 25, 0.2);
}

.ranking-grid {
  position: relative;
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  gap: 24rpx;
  align-items: start;
}

.divider {
  background: #f1f3f5;
  width: 1px;
}

.col-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding-bottom: 12rpx;
  margin-bottom: 20rpx;
  border-bottom: 6rpx solid;
  font-size: 30rpx;
  font-weight: 900;
  color: #212529;
}

.col-title.red {
  border-color: #fcc419;
}

.col-title.black {
  border-color: #212529;
}

.col-icon {
  font-size: 28rpx;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.list-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 16rpx 18rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.02);
}

.list-item.top1 {
  background: #fcf8e8;
  border: 1rpx solid rgba(252, 196, 25, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(252, 196, 25, 0.12);
}

.list-item.bottom1 {
  background: #1a1a1e;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.rank-number {
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
  color: rgba(142, 154, 175, 0.4);
}

.rank-number.danger {
  color: #fa5252;
  background: rgba(250, 82, 82, 0.1);
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
}

.user-name {
  font-size: 26rpx;
  font-weight: 900;
  color: rgba(26, 26, 30, 0.8);
}

.user-name.light {
  color: #ffffff;
}

.score {
  font-size: 22rpx;
  font-weight: 900;
}

.yellow-score {
  color: #fcc419;
}

.red-score {
  color: #fa5252;
}

.footnote {
  margin-top: 40rpx;
  text-align: center;
  font-size: 18rpx;
  color: rgba(142, 154, 175, 0.4);
  text-transform: uppercase;
  letter-spacing: 1rpx;
}
