<view class="profile-page page-shell">
  <view class="page-orb page-orb--gold"></view>
  <view class="profile-section">
    <view class="avatar-wrap">
      <image class="avatar" src="/images/user_avatar.png" />
      <view class="avatar-badge">🛡</view>
    </view>
    <view class="name-row">
      <text class="name">{{profile.nickname || '-'}}</text>
      <text class="level-tag">{{profile.userLevel || '-'}}</text>
    </view>
    <text class="user-id">ID: {{profile.userId || '-'}}</text>
  </view>

  <view class="card credit-card">
    <view class="credit-header">
      <view>
        <text class="credit-label">摸金信誉分数</text>
        <view class="credit-value-row">
          <text class="credit-score">{{creditScore}}</text>
          <view class="shield-icon">🛡</view>
        </view>
      </view>
      <view class="credit-right">
        <text class="credit-label">摸金值余额</text>
        <text class="credit-balance">{{profile.mojinBalance || '-'}}</text>
        <text class="credit-lock">含锁定 {{profile.mojinLocked || '-'}}</text>
      </view>
    </view>

    <view class="checkin-card">
      <view class="checkin-header">
        <text class="checkin-title">7日签到福利</text>
        <text class="checkin-days">已累计: {{checkinDays}}天</text>
      </view>
      <view class="checkin-grid">
        <block wx:for="{{checkinRewards}}" wx:key="index">
          <view class="checkin-item {{item.active ? 'active' : ''}}">
            <text>{{item.label}}</text>
          </view>
        </block>
      </view>
      <button class="checkin-btn" bindtap="claimCheckin" disabled="{{checkinSignedToday || checkinLoading}}">
        {{checkinSignedToday ? '今日已签到' : '签到领取锁定摸金值'}}
      </button>
    </view>

    <view class="credit-actions">
      <button class="action-btn primary" bindtap="goCredit">↗ 摸金充值</button>
      <button class="action-btn secondary" bindtap="goExchange">⇄ 金兑信誉</button>
    </view>
  </view>

  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-value">{{stats.activeContracts}}</text>
      <text class="stat-label">进行中契约</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.completedContracts}}</text>
      <text class="stat-label">已完成总数</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.successRate}}</text>
      <text class="stat-label">履约胜率</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goArbitration">
      <view class="menu-item-left">
        <view class="menu-icon">⚖️</view>
        <view>
          <text class="menu-title">仲裁中心</text>
          <text class="menu-desc">处理契约纠纷与申诉</text>
        </view>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <view class="menu-item" bindtap="goCreditHistory">
      <view class="menu-item-left">
        <view class="menu-icon">💰</view>
        <view>
          <text class="menu-title">我的信誉分记录</text>
          <text class="menu-desc">保证金与酬劳流水</text>
        </view>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <view class="menu-item" bindtap="goContractReport">
      <view class="menu-item-left">
        <view class="menu-icon">📊</view>
        <view>
          <text class="menu-title">契约统计报告</text>
          <text class="menu-desc">近期契约执行情况</text>
        </view>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <view class="menu-item" bindtap="goUserInfo">
      <view class="menu-item-left">
        <view class="menu-icon">🔐</view>
        <view>
          <text class="menu-title">账号与安全</text>
          <text class="menu-desc">实名认证与密码设置</text>
        </view>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <view class="menu-item" bindtap="goNotifySettings">
      <view class="menu-item-left">
        <view class="menu-icon">🔔</view>
        <view>
          <text class="menu-title">消息通知设置</text>
          <text class="menu-desc">推送通知开关</text>
        </view>
      </view>
      <text class="arrow-icon">›</text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <view class="menu-item-left">
        <view class="menu-icon">ℹ️</view>
        <view>
          <text class="menu-title">关于摸金小契</text>
          <text class="menu-desc">平台介绍与服务协议</text>
        </view>
      </view>
      <text class="arrow-icon">›</text>
    </view>
  </view>

  <view class="logout-card" bindtap="logout">
    <text class="logout-text">⟵ 退出当前账号</text>
  </view>
</view>
