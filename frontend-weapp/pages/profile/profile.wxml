<view class="container profile-page paper-page">
  <view class="paper-card parchment-card">
    <view class="profile-header">
      <view class="profile-avatar"></view>
      <view class="profile-name">{{profile.nickname || '未命名用户'}}</view>
    </view>
  </view>

  <view class="paper-card parchment-card">
    <view class="grid">
      <view class="grid-item" bindtap="goUserInfo">
        <view class="grid-icon">信息</view>
        <view class="grid-label">用户信息</view>
      </view>
      <view class="grid-item" bindtap="goCredit">
        <view class="grid-icon">信用</view>
        <view class="grid-label">信用分详情</view>
      </view>
      <view class="grid-item" bindtap="goVipCenter">
        <view class="grid-icon">特权</view>
        <view class="grid-label">特权中心</view>
      </view>
    </view>
  </view>

  <view class="profile-footer">
    <button class="btn-outline" bindtap="logout">退出登录</button>
  </view>
</view>
