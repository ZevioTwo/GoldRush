.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.account-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(16, 24, 40, 0.06);
  border: 1rpx solid rgba(16, 24, 40, 0.04);
}

.actions {
  margin-top: 12rpx;
  justify-content: flex-end;
  gap: 12rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.picker {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  box-shadow: inset 0 1rpx 2rpx rgba(16, 24, 40, 0.05);
}

.action-btn {
  border-radius: 10rpx;
  font-size: 26rpx;
  padding: 10rpx 18rpx;
}

.action-btn.primary {
  background-color: #FFC107;
  color: #333;
}

.action-btn.secondary {
  background-color: #f0f0f0;
  color: #666;
}

.action-btn::after {
  border: none;
}
