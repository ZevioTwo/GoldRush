.account-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(16, 24, 40, 0.06);
  border: 1rpx solid rgba(16, 24, 40, 0.04);
}

.actions {
  margin-top: 12rpx;
  justify-content: flex-end;
  gap: 12rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #5e6572;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.picker {
  background: #f3f4f6;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}
