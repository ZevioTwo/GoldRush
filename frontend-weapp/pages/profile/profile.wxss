.profile-page {
  position: relative;
  overflow: hidden;
}

.profile-page::before {
  content: "";
  position: absolute;
  top: -120rpx;
  right: -120rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(252, 248, 232, 0.5);
  border-radius: 50%;
  filter: blur(30rpx);
  z-index: 0;
}

.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 42rpx;
  position: relative;
  z-index: 1;
  padding-top: 8rpx;
}

.avatar-wrap {
  position: relative;
  margin-bottom: 20rpx;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(0,0,0,0.12);
}

.avatar-badge {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #d9a42b;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 20rpx;
  border: 2rpx solid #fff;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name {
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-foreground);
}

.user-id {
  font-size: 26rpx;
  color: var(--color-muted-foreground);
  margin-top: 6rpx;
  letter-spacing: 2rpx;
}

.level-tag {
  background-color: #fff9db;
  color: #d9a42b;
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(217,164,43,0.15);
  font-weight: 900;
  text-transform: uppercase;
}

.card {
  background-color: #fff;
  border-radius: 48rpx;
  padding: 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0,0,0,0.05);
  position: relative;
  z-index: 1;
}

.credit-card {
  overflow: hidden;
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.credit-label {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.6);
  font-weight: 900;
  letter-spacing: 2rpx;
}

.credit-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.credit-score {
  font-size: 64rpx;
  font-weight: 900;
  color: #212529;
  line-height: 1;
}

.shield-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 16rpx;
  background: #fff9db;
  color: #d9a42b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.15);
}

.credit-right {
  text-align: right;
}

.credit-balance {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--color-foreground);
}

.credit-lock {
  font-size: 20rpx;
  color: #d9a42b;
  font-weight: 700;
  background: #fcf8e8;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
}

.checkin-card {
  background: #f8f9fa;
  border-radius: 36rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(0,0,0,0.03);
  margin-bottom: 24rpx;
}

.checkin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.checkin-title {
  font-size: 24rpx;
  font-weight: 900;
  color: #212529;
}

.checkin-days {
  font-size: 20rpx;
  color: var(--color-muted-foreground);
  font-weight: 700;
}

.checkin-grid {
  display: flex;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.checkin-item {
  flex: 1;
  aspect-ratio: 1 / 1;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 900;
  color: rgba(142, 154, 175, 0.4);
}

.checkin-item.active {
  background: #d9a42b;
  color: #ffffff;
  border-color: #d9a42b;
}

.checkin-btn {
  width: 100%;
  background: #ffffff;
  border: 2rpx solid rgba(217, 164, 43, 0.2);
  border-radius: 24rpx;
  padding: 18rpx 0;
  font-size: 24rpx;
  font-weight: 900;
  color: #d9a42b;
}

.credit-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  border-radius: 24rpx;
  padding: 18rpx 0;
  margin: 0;
  font-weight: 900;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
}

.action-btn.secondary {
  background-color: #fff;
  color: #d9a42b;
  border: 1rpx solid rgba(217, 164, 43, 0.1);
}

.stats-card {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  background: rgba(255,255,255,0.62);
  padding: 8rpx;
  border-radius: 36rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.stat-item {
  text-align: center;
  background: #fff;
  border-radius: 28rpx;
  padding: 24rpx 10rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.04);
}

.stat-value {
  font-size: 34rpx;
  font-weight: 900;
  display: block;
  margin-bottom: 8rpx;
  color: #212529;
}

.stat-label {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.8);
  font-weight: 700;
}

.menu-card {
  background: #fff;
  border-radius: 48rpx;
  padding: 6rpx 0;
  border: 1rpx solid rgba(0,0,0,0.05);
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(0,0,0,0.03);
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.menu-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f5f6f7 0%, #f1f3f5 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e9aaf;
  font-size: 28rpx;
}

.menu-title {
  font-size: 28rpx;
  color: #212529;
  font-weight: 800;
}

.menu-desc {
  font-size: 20rpx;
  color: rgba(142, 154, 175, 0.8);
}

.arrow-icon {
  font-size: 32rpx;
  color: rgba(142, 154, 175, 0.4);
}

.logout-card {
  text-align: center;
  padding: 26rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(0,0,0,0.05);
  background: rgba(255,255,255,0.94);
  position: relative;
  z-index: 1;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.02);
}

.logout-text {
  color: #fa5252;
  font-size: 30rpx;
  font-weight: 900;
}
