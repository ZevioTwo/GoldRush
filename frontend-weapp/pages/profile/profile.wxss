.row text:first-child {
  margin-right: 12rpx;
}

.profile-header {
  text-align: center;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f3e4cf;
  border: 2rpx solid rgba(125, 88, 49, 0.35);
  margin: 0 auto 16rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #4a2f1d;
}

.profile-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.profile-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 150rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.grid-item {
  background: rgba(255, 252, 244, 0.9);
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(125, 88, 49, 0.18);
  box-shadow: inset 0 2rpx 6rpx rgba(122, 90, 65, 0.12);
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #f6e7cf;
  color: #8b4a2b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin: 0 auto 12rpx;
  border: 1rpx solid rgba(125, 88, 49, 0.25);
}

.grid-label {
  font-size: 24rpx;
  color: #4a2f1d;
}
