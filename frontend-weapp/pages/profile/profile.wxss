.container {
  background-color: #f8f8f8;
  padding: 30rpx;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.profile-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD700;
  margin-bottom: 20rpx;
}

.name {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-id {
  font-size: 28rpx;
  color: #999;
}

.credit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.credit-label {
  font-size: 28rpx;
  color: #666;
}

.ranking-link {
  font-size: 24rpx;
  color: #999;
}

.level-tag {
  background-color: #fffbe6;
  color: #FFC107;
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 20rpx;
  margin-left: auto;
}

.credit-score-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.credit-score {
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
  margin-right: 10rpx;
}

.shield-icon {
  font-size: 36rpx;
  color: #FFC107;
  margin-right: 10rpx;
}

.credit-progress {
  margin-bottom: 30rpx;
}

.credit-actions {
  display: flex;
}

.action-btn {
  flex: 1;
  font-size: 28rpx;
  border-radius: 10rpx;
  padding: 18rpx 0;
  margin: 0;
}

.action-btn.primary {
  background-color: #FFC107;
  color: #fff;
  margin-right: 20rpx;
}

.action-btn.secondary {
  background-color: #f0f0f0;
  color: #666;
}

.stats-card {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.menu-card {
  padding: 10rpx 30rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  color: #666;
  margin-right: 20rpx;
}

.menu-title {
  font-size: 30rpx;
  color: #333;
}

.arrow-icon {
  font-size: 28rpx;
  color: #ccc;
}

.logout-card {
  text-align: center;
  padding: 30rpx;
}

.logout-text {
  color: #F44336;
  font-size: 30rpx;
}
