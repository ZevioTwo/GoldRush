.row text:first-child {
  margin-right: 12rpx;
}

.profile-header {
  text-align: center;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e5e7eb;
  margin: 0 auto 16rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
}

.profile-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.profile-footer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 150rpx;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.grid-item {
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.grid-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  background: #e8f0ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin: 0 auto 12rpx;
}

.grid-label {
  font-size: 24rpx;
  color: #1f2329;
}
