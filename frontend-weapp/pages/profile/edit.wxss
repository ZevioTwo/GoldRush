.container {
  background-color: #f8f8f8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  box-shadow: inset 0 1rpx 2rpx rgba(16, 24, 40, 0.05);
}

.action-btn {
  border-radius: 10rpx;
  font-size: 30rpx;
  margin-top: 16rpx;
  background-color: #FFC107;
  color: #333;
}

.action-btn::after {
  border: none;
}
