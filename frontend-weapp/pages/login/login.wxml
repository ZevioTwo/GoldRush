<view class="login-page">
  <view class="login-card">
    <image class="login-logo" src="/images/user_avatar.png" mode="aspectFit"></image>
    <view class="login-title">欢迎登录</view>
    <view class="login-subtitle">使用微信一键登录</view>
    <button class="login-btn" open-type="getUserInfo" bindtap="handleLogin">微信登录</button>
  </view>
</view>
