.chat-page {
  position: relative;
  overflow: hidden;
}

.chat-page--reply {
  padding-bottom: calc(260rpx + env(safe-area-inset-bottom));
}

.chat-header,
.message-scroll,
.loading-card,
.composer {
  position: relative;
  z-index: 1;
}

.chat-header {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
}

.chat-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 26rpx;
  background: #f1f3f5;
}

.chat-copy {
  flex: 1;
  min-width: 0;
}

.chat-name {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #1f2933;
}

.chat-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8e9aaf;
}

.message-scroll {
  height: calc(100vh - 340rpx);
}

.chat-page--reply .message-scroll {
  height: calc(100vh - 470rpx);
}

.message-row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 18rpx;
}

.message-row--self {
  align-items: flex-end;
}

.message-row--system {
  align-items: center;
}

.bubble {
  max-width: 78%;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.05);
}

.bubble--other {
  background: #ffffff;
  color: #1f2933;
}

.bubble--self {
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
}

.bubble-text {
  font-size: 26rpx;
  line-height: 1.75;
  white-space: pre-wrap;
  word-break: break-word;
}

.bubble-time,
.system-time {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #9aa5b1;
}

.system-bubble {
  width: 100%;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(217, 164, 43, 0.08);
  border: 1rpx solid rgba(217, 164, 43, 0.12);
  text-align: center;
}

.system-text {
  display: block;
  font-size: 24rpx;
  color: #7a6a36;
  line-height: 1.8;
}

.composer {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 16rpx 36rpx rgba(15, 23, 42, 0.08);
}

.composer-input {
  flex: 1;
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  background: #f8f9fa;
  font-size: 26rpx;
  color: #1f2933;
}

.composer-placeholder {
  color: #b1bac7;
}

.composer-send {
  min-width: 132rpx;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e3b447 0%, #d9a42b 100%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 900;
}

.composer-send::after {
  border: none;
}

.loading-card,
.empty-block {
  padding: 36rpx 24rpx;
  text-align: center;
  font-size: 24rpx;
  color: #7a869a;
}
