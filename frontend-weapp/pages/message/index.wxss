.message-page {
  position: relative;
  overflow: hidden;
}

.page-header,
.search-bar,
.session-list,
.empty-card,
.loading-card {
  position: relative;
  z-index: 1;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 900;
  color: var(--color-foreground);
}

.page-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: var(--color-muted-foreground);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.04);
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #9aa5b1;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1f2933;
}

.search-placeholder {
  color: #b1bac7;
}

.session-card {
  display: flex;
  gap: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: linear-gradient(180deg, #fffdf7 0%, #fff9ef 100%);
  border: 1rpx solid rgba(217, 164, 43, 0.08);
}

.session-card--highlight {
  background: linear-gradient(180deg, #fff9ec 0%, #fff5e2 100%);
  border-color: rgba(217, 164, 43, 0.14);
}

.avatar-shell {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #f1f3f5;
}

.unread-badge {
  position: absolute;
  top: -6rpx;
  right: -8rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #fa5252;
  color: #fff;
  font-size: 18rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 16rpx rgba(250, 82, 82, 0.28);
}

.session-main {
  flex: 1;
  min-width: 0;
}

.session-top,
.session-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.session-top {
  margin-bottom: 12rpx;
}

.title-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.session-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #1f2933;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-tag {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(217, 164, 43, 0.12);
  color: #d9a42b;
  font-size: 18rpx;
  font-weight: 900;
}

.session-time {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #8e9aaf;
}

.session-preview {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  color: #5b6675;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-type {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #a3acb9;
}

.empty-card,
.loading-card {
  padding: 40rpx 28rpx;
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #1f2933;
}

.empty-desc,
.loading-card {
  font-size: 24rpx;
  line-height: 1.8;
  color: #7a869a;
}

.empty-desc {
  display: block;
  margin-top: 12rpx;
}
