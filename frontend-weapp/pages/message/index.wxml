<view class="message-page page-shell page-shell--white">
  <view class="page-orb page-orb--gold"></view>
  <view class="page-orb page-orb--soft"></view>

  <view class="page-header">
    <view>
      <text class="page-title">消息中心</text>
      <text class="page-subtitle">接收系统通知，并和已接取契约的玩家私聊沟通</text>
    </view>
  </view>

  <view class="search-bar">
    <text class="search-icon">⌕</text>
    <input
      class="search-input"
      placeholder="搜索联系人、契约编号或消息内容"
      placeholder-class="search-placeholder"
      value="{{keyword}}"
      bindinput="onKeywordInput"
    />
  </view>

  <view wx:if="{{loading}}" class="loading-card floating-card">消息加载中...</view>

  <view wx:elif="{{filteredSessions.length > 0}}" class="session-list">
    <block wx:for="{{filteredSessions}}" wx:key="sessionId">
      <view class="session-card floating-card {{item.highlight ? 'session-card--highlight' : ''}}" bindtap="openSession" data-id="{{item.sessionId}}">
        <view class="avatar-shell">
          <image class="avatar" src="{{item.peerAvatar}}" mode="aspectFill" binderror="onAvatarError" data-index="{{index}}"></image>
          <view wx:if="{{item.unread}}" class="unread-badge">{{item.unreadDisplay}}</view>
        </view>

        <view class="session-main">
          <view class="session-top">
            <view class="title-wrap">
              <text class="session-name">{{item.peerName}}</text>
              <text class="session-tag">{{item.peerTag}}</text>
            </view>
            <text class="session-time">{{item.lastTimeDisplay || '刚刚'}}</text>
          </view>

          <view class="session-bottom">
            <text class="session-preview">{{item.lastMessage}}</text>
            <text class="session-type">{{item.typeLabel}}</text>
          </view>
        </view>
      </view>
    </block>
  </view>

  <view wx:else class="empty-card floating-card">
    <text class="empty-title">还没有消息</text>
    <text class="empty-desc">当有系统通知，或者有玩家接取契约后，就会在这里出现消息会话。</text>
  </view>
</view>
