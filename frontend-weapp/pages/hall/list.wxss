.container {
  background-color: #f4f4f4;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #fff;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
}

.icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  background-color: #f0f0f0;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.header-icon {
  font-size: 28rpx;
  color: #333;
}

.game-tabs {
  white-space: nowrap;
  padding: 20rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  background-color: #f0f0f0;
  border-radius: 30rpx;
  margin-right: 20rpx;
}

.tab-item.active {
  background-color: #FFD700;
  color: #333;
  font-weight: bold;
}

.search-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  margin: 20rpx 30rpx;
  border-radius: 10rpx;
}

.search-icon {
  margin-right: 15rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.contract-list {
  padding: 20rpx 30rpx;
}

.contract-card {
  background-color: #fff;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.card-banner {
  width: 100%;
  height: 240rpx;
}

.card-content {
  padding: 20rpx 30rpx;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
}

.status-tag {
  font-size: 24rpx;
  padding: 5rpx 15rpx;
  border-radius: 8rpx;
  color: #fff;
  background-color: #4CAF50;
}

.card-info-row {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
}

.card-requirement {
  font-size: 26rpx;
  color: #666;
  margin-top: 20rpx;
  line-height: 1.5;
}

.details-button {
  background-color: #FFD700;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
  margin-top: 30rpx;
  padding: 20rpx 0;
  text-align: center;
}

.details-button::after {
  border: none;
}
