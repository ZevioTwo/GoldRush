.hall-page {
  background-color: var(--color-background);
  min-height: 100vh;
  padding-bottom: 180rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx 16rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 900;
  color: var(--color-foreground);
}

.icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background-color: #fcf8e8;
  border-radius: 999rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.header-icon {
  font-size: 28rpx;
  color: #d9a42b;
}

.notify-dot {
  position: absolute;
  top: 10rpx;
  right: 12rpx;
  width: 12rpx;
  height: 12rpx;
  background: var(--color-destructive);
  border-radius: 50%;
  border: 2rpx solid var(--color-background);
}

.dropdown {
  position: relative;
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.dropdown-trigger {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.03);
}

.dropdown-trigger.active {
  border-color: rgba(217, 164, 43, 0.5);
  box-shadow: 0 6rpx 20rpx rgba(217, 164, 43, 0.15);
}

.dropdown-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dropdown-icon {
  font-size: 28rpx;
  color: #d9a42b;
}

.dropdown-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #212529;
}

.dropdown-arrow {
  font-size: 28rpx;
  color: #adb5bd;
  transition: transform 0.3s ease;
}

.dropdown-arrow.open {
  transform: rotate(180deg);
  color: #d9a42b;
}

.dropdown-panel {
  position: absolute;
  top: 100rpx;
  left: 24rpx;
  right: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e9ecef;
  border-radius: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.08);
  z-index: 20;
  overflow: hidden;
}

.dropdown-search {
  padding: 16rpx;
  border-bottom: 1rpx solid #f1f3f5;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dropdown-search .search-input {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  flex: 1;
}

.dropdown-list {
  max-height: 420rpx;
}

.dropdown-item {
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #495057;
}

.dropdown-item.active {
  background: #fff9db;
  color: #d9a42b;
  font-weight: 800;
}

.check-icon {
  font-weight: 800;
}

.contract-list {
  padding: 0 24rpx 30rpx;
}

.contract-card {
  background-color: #fff;
  border-radius: 48rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card-banner {
  width: 100%;
  height: 300rpx;
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0) 0%, rgba(0,0,0,0.45) 100%);
}

.card-content {
  padding: 28rpx;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 12rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 900;
  color: #1a1a1e;
  flex: 1;
}

.status-pill {
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: 800;
}

.status-pill.warning {
  background: #fff9db;
  color: #d9a42b;
}

.status-pill.success {
  background: #e7f9ee;
  color: #22c55e;
}

.card-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  font-size: 22rpx;
  color: var(--color-muted-foreground);
  margin-bottom: 16rpx;
}

.meta-highlight {
  color: #d9a42b;
  font-weight: 900;
}

.risk-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(252, 248, 232, 0.3);
  border: 1rpx solid rgba(217, 164, 43, 0.1);
  padding: 20rpx;
  border-radius: 28rpx;
  margin-bottom: 16rpx;
}

.risk-title {
  font-size: 18rpx;
  color: rgba(217, 164, 43, 0.6);
  font-weight: 800;
  text-transform: uppercase;
}

.risk-desc {
  font-size: 24rpx;
  color: var(--color-muted-foreground);
  font-weight: 700;
}

.risk-right {
  text-align: right;
}

.risk-value {
  font-size: 30rpx;
  font-weight: 900;
  color: #d9a42b;
}

.card-desc {
  font-size: 24rpx;
  color: var(--color-muted-foreground);
  line-height: 1.6;
  background: #f8f9fa;
  padding: 16rpx 20rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.03);
  margin-bottom: 18rpx;
}

.details-button {
  background-color: #d9a42b;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  border-radius: 24rpx;
  padding: 20rpx 0;
  text-align: center;
  box-shadow: 0 12rpx 30rpx rgba(217, 164, 43, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.details-button::after {
  border: none;
}

.detail-arrow {
  font-size: 30rpx;
}
