.row text:first-child {
  margin-right: 12rpx;
}

.hall-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  box-sizing: border-box;
}

.list-area {
  min-height: 1100rpx;
}

.parchment-card {
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
}

.parchment-input {
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  box-shadow: inset 0 1rpx 2rpx rgba(16, 24, 40, 0.05);
}

.wax-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border: none;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28);
}

.wax-btn::after {
  border: none;
}
