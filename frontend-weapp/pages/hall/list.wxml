<view class="hall-page">
  <view class="header">
    <view class="icon-wrapper" bindtap="onSearchIcon">
      <text class="header-icon">🔍</text>
    </view>
    <text class="header-title">契约大厅</text>
    <view class="icon-wrapper">
      <text class="header-icon">🔔</text>
      <view class="notify-dot"></view>
    </view>
  </view>

  <view class="dropdown" bindtap="toggleDropdown">
    <view class="dropdown-trigger {{dropdownOpen ? 'active' : ''}}">
      <view class="dropdown-left">
        <text class="dropdown-icon">🎮</text>
        <text class="dropdown-text">{{activeTabLabel}}</text>
      </view>
      <text class="dropdown-arrow {{dropdownOpen ? 'open' : ''}}">⌄</text>
    </view>

    <view wx:if="{{dropdownOpen}}" class="dropdown-panel">
      <view class="dropdown-search">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="搜索游戏..." value="{{searchTerm}}" bindinput="onSearchInput" />
      </view>
      <scroll-view scroll-y="true" class="dropdown-list">
        <view
          wx:for="{{filteredGames}}"
          wx:key="value"
          class="dropdown-item {{activeTab === item.value ? 'active' : ''}}"
          data-tab="{{item.value}}"
          bindtap="onTabChange"
        >
          <text>{{item.label}}</text>
          <text wx:if="{{activeTab === item.value}}" class="check-icon">✓</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="contract-list">
    <block wx:for="{{list}}" wx:key="contractId">
      <view class="contract-card" bindtap="goDetail" data-id="{{item.contractId}}">
        <view class="card-banner">
          <image class="banner-img" src="{{item.image}}" mode="aspectFill"></image>
          <view class="banner-mask"></view>
        </view>
        <view class="card-content">
          <view class="card-title-row">
            <text class="card-title">{{item.title}}</text>
            <text class="status-pill {{item.statusClass}}">{{item.statusLabel}}</text>
          </view>
          <view class="card-meta-grid">
            <view class="meta-item">👤 发起人：{{item.boss}}</view>
            <view class="meta-item">🎮 游戏：{{item.game}}</view>
            <view class="meta-item">🛡 信誉分门槛：<text class="meta-highlight">{{item.credit}}</text></view>
            <view class="meta-item">⏱ 剩 {{item.remaining}}</view>
          </view>
          <view class="risk-card">
            <view>
              <text class="risk-title">契约信用保障</text>
              <text class="risk-desc">违约即扣除对应信誉分</text>
            </view>
            <view class="risk-right">
              <text class="risk-title">需押信誉分</text>
              <text class="risk-value">{{item.deposit}} 信誉分</text>
            </view>
          </view>
          <view class="card-desc">{{item.desc}}</view>
          <button class="details-button" catchtap="goDetail" data-id="{{item.contractId}}">
            查看详情
            <text class="detail-arrow">›</text>
          </button>
        </view>
      </view>
    </block>

    <view wx:if="{{list.length === 0}}" class="empty-state" style="margin-top: 48rpx;">
      暂无待接单契约
    </view>

    <view wx:if="{{loading}}" class="loading-state" style="margin: 24rpx 0;">加载中...</view>
    <view wx:if="{{!hasMore && list.length > 0}}" class="empty-state" style="margin: 24rpx 0;">没有更多了</view>
  </view>
</view>
