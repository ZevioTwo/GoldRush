.tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(16rpx + env(safe-area-inset-bottom));
  height: 116rpx;
  z-index: 100;
}

.tabbar-bg {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.94);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow: 0 14rpx 32rpx rgba(15, 23, 42, 0.08);
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  align-items: center;
  height: 100%;
  padding: 10rpx 14rpx;
  box-sizing: border-box;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  min-height: 84rpx;
  border-radius: 28rpx;
  transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
  opacity: 0.92;
}

.tabbar-item.is-active {
  background: linear-gradient(180deg, rgba(252, 196, 25, 0.16) 0%, rgba(252, 196, 25, 0.08) 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  opacity: 1;
}

.tabbar-icon-wrap {
  width: 42rpx;
  height: 42rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.tabbar-icon-wrap.is-active {
  background: transparent;
  box-shadow: none;
}

.tabbar-icon {
  width: 36rpx;
  height: 36rpx;
  opacity: 0.82;
}

.tabbar-icon.is-active {
  opacity: 1;
}

.tabbar-text {
  font-size: 22rpx;
  color: #8e9aaf;
  font-weight: 700;
  line-height: 1;
}

.tabbar-text.is-active {
  color: #d9a42b;
  font-weight: 900;
}
