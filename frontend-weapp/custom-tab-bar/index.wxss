.tabbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  height: 132rpx;
  z-index: 100;
}

.tabbar-bg {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  top: 0;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(15, 23, 42, 0.04);
  backdrop-filter: blur(18px);
  -webkit-backdrop-filter: blur(18px);
  box-shadow: 0 18rpx 45rpx rgba(15, 23, 42, 0.08);
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  height: 100%;
  padding: 10rpx 18rpx 16rpx;
  box-sizing: border-box;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  transition: transform 0.2s ease, opacity 0.2s ease;
  opacity: 0.88;
}

.tabbar-item.is-active {
  transform: translateY(-6rpx);
  opacity: 1;
}

.tabbar-icon-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.tabbar-icon-wrap.is-active {
  background: rgba(252, 196, 25, 0.16);
  box-shadow: 0 10rpx 24rpx rgba(252, 196, 25, 0.12);
}

.tabbar-icon {
  width: 44rpx;
  height: 44rpx;
}

.tabbar-text {
  font-size: 22rpx;
  color: #8e9aaf;
  font-weight: 700;
}

.tabbar-text.is-active {
  color: #d9a42b;
  font-weight: 800;
}
