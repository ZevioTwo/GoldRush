.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 130rpx;
  z-index: 100;
}

.tabbar-bg {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  height: 104rpx;
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
  box-shadow:
    0 14rpx 28rpx rgba(16, 24, 40, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.9);
}

.tabbar-bg::before {
  content: "";
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: 8rpx;
  height: 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0));
  opacity: 0.7;
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  height: 100%;
  padding: 10rpx 24rpx 26rpx;
  box-sizing: border-box;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #94a3b8;
}

.tabbar-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
  color: #64748b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transition: all 0.22s ease;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
  box-shadow: 0 6rpx 14rpx rgba(16, 24, 40, 0.08);
}

.tabbar-text {
  font-size: 22rpx;
  color: #94a3b8;
  transition: all 0.22s ease;
}

.tabbar-icon.is-active {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  box-shadow:
    0 10rpx 20rpx rgba(37, 99, 235, 0.35);
  transform: translateY(-6rpx) scale(1.04);
  border: none;
}

.tabbar-text.is-active {
  color: #2563eb;
  font-weight: 700;
}
