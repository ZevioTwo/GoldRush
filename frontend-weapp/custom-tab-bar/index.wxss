.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  z-index: 100;
}

.tabbar-bg {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 140rpx;
  background: rgba(255, 255, 255, 0.8);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  box-shadow: 0 -10rpx 30rpx rgba(0, 0, 0, 0.03);
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  height: 100%;
  padding: 14rpx 24rpx 26rpx;
  box-sizing: border-box;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: transform 0.2s ease;
}

.tabbar-item.is-active {
  transform: scale(1.08);
}

.tabbar-icon {
  width: 44rpx;
  height: 44rpx;
}

.tabbar-text {
  font-size: 22rpx;
  color: #8e9aaf;
  font-weight: 600;
}

.tabbar-text.is-active {
  color: #d9a42b;
  font-weight: 800;
}
