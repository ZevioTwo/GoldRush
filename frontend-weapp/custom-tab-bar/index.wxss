.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 130rpx;
  z-index: 100;
}

.tabbar-bg {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  height: 104rpx;
  background: linear-gradient(180deg, rgba(255, 253, 246, 0.98), rgba(242, 225, 198, 0.96));
  border-radius: 30rpx;
  border: 1rpx solid rgba(175, 132, 86, 0.4);
  box-shadow:
    0 18rpx 38rpx rgba(125, 88, 49, 0.35),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.8),
    inset 0 -8rpx 14rpx rgba(126, 88, 51, 0.25);
}

.tabbar-bg::before {
  content: "";
  position: absolute;
  left: 10rpx;
  right: 10rpx;
  top: 8rpx;
  height: 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(255, 255, 255, 0));
  opacity: 0.7;
}

.tabbar-bg::after {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: 34rpx;
  border: 1rpx solid rgba(255, 232, 186, 0.6);
  box-shadow: 0 0 16rpx rgba(255, 218, 151, 0.35);
  pointer-events: none;
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  height: 100%;
  padding: 10rpx 24rpx 26rpx;
  box-sizing: border-box;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #8b929c;
}

.tabbar-icon {
  width: 58rpx;
  height: 58rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f7ead3, #e9d2ae);
  color: #8b4a2b;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transition: all 0.22s ease;
  border: 1rpx solid rgba(145, 102, 62, 0.3);
  box-shadow:
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.7),
    inset 0 -4rpx 8rpx rgba(125, 88, 49, 0.25),
    0 6rpx 14rpx rgba(109, 78, 47, 0.22);
}

.tabbar-text {
  font-size: 22rpx;
  color: #8b7a6b;
  transition: all 0.22s ease;
  text-shadow: 0 1rpx 0 rgba(255, 255, 255, 0.5);
}

.tabbar-icon.is-active {
  background: radial-gradient(circle at 30% 30%, #e75a4a, #a0231b 70%);
  color: #fff;
  box-shadow:
    0 10rpx 22rpx rgba(155, 45, 36, 0.5),
    0 0 18rpx rgba(255, 122, 102, 0.65),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.45);
  transform: translateY(-8rpx) scale(1.04);
  border: 1rpx solid rgba(255, 226, 170, 0.85);
}

.tabbar-icon.is-active::after {
  content: "";
  position: absolute;
  inset: -6rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 225, 168, 0.9);
  box-shadow: 0 0 16rpx rgba(255, 204, 128, 0.8);
  opacity: 0.9;
}

.tabbar-text.is-active {
  color: #a0231b;
  font-weight: 700;
  text-shadow: 0 0 10rpx rgba(255, 180, 140, 0.6);
}
