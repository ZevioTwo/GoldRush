.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 130rpx;
  z-index: 100;
}

.tabbar-bg {
  position: absolute;
  left: 16rpx;
  right: 16rpx;
  bottom: 16rpx;
  height: 104rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16rpx);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(16, 24, 40, 0.12);
  border: 1rpx solid rgba(16, 24, 40, 0.06);
}

.tabbar-inner {
  position: relative;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  align-items: center;
  height: 100%;
  padding: 10rpx 24rpx 26rpx;
  box-sizing: border-box;
}

.tabbar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #8b929c;
}

.tabbar-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: #f2f4f7;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.tabbar-text {
  font-size: 22rpx;
  color: #8b929c;
  transition: all 0.2s ease;
}

.tabbar-icon.is-active {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.28);
  transform: translateY(-6rpx);
}

.tabbar-text.is-active {
  color: #2563eb;
  font-weight: 600;
}
