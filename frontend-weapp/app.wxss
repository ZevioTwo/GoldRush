page {
  background: #f8f8f8;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
}

.paper-page {
  min-height: 100vh;
  background: #f8f8f8;
}

.paper-card {
  position: relative;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.06);
  box-shadow: 0 12rpx 24rpx rgba(16, 24, 40, 0.08);
  overflow: hidden;
}

.paper-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: 24rpx;
  right: 24rpx;
  height: 2rpx;
  background: linear-gradient(90deg, rgba(74, 144, 226, 0), rgba(74, 144, 226, 0.2), rgba(74, 144, 226, 0));
  opacity: 0.6;
}

.paper-divider {
  height: 2rpx;
  background: linear-gradient(90deg, rgba(16, 24, 40, 0), rgba(16, 24, 40, 0.12), rgba(16, 24, 40, 0));
  margin: 16rpx 0;
}

.paper-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2329;
  letter-spacing: 0.6rpx;
}

.paper-label {
  color: #6b7280;
}

.paper-subtle {
  color: #94a3b8;
}

.card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 20rpx rgba(16, 24, 40, 0.06);
  border: 1rpx solid rgba(16, 24, 40, 0.04);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.text-muted {
  color: #8b929c;
}

/* Buttons */
button {
  font-size: 28rpx;
  border-radius: 999rpx;
}

.btn {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.25);
  padding: 18rpx 26rpx;
  border-radius: 999rpx;
}

.btn-outline {
  border: 2rpx solid rgba(37, 99, 235, 0.35);
  color: #2563eb;
  background: #ffffff;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
}

button[disabled] {
  opacity: 0.55;
}

/* Form */
.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #6b7280;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.textarea,
.picker,
.readonly {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  box-shadow: inset 0 1rpx 2rpx rgba(16, 24, 40, 0.05);
}

.readonly {
  color: #1f2329;
}

.textarea {
  min-height: 160rpx;
}

/* Status / Tag */
.status-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #1f2329;
  background: #f1f5f9;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
}

.status-badge--success {
  color: #166534;
  border-color: rgba(22, 101, 52, 0.25);
  background: rgba(220, 252, 231, 0.9);
}

.status-badge--warning {
  color: #92400e;
  border-color: rgba(146, 64, 14, 0.25);
  background: rgba(254, 243, 199, 0.95);
}

.status-badge--danger {
  color: #991b1b;
  border-color: rgba(153, 27, 27, 0.25);
  background: rgba(254, 226, 226, 0.95);
}

.status-PENDING {
  background-color: #FF9800;
}

.status-PAID,
.status-ACTIVE,
.status-IN_GAME {
  background-color: #4CAF50;
}

.status-COMPLETED {
  background-color: #2196F3;
}

.status-CANCELLED,
.status-VIOLATED {
  background-color: #9E9E9E;
}

.status-DISPUTE {
  background-color: #F44336;
}

/* Empty / Loading */
.empty-state,
.loading-state {
  text-align: center;
  padding: 28rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.08);
  color: #64748b;
  box-shadow: 0 8rpx 16rpx rgba(16, 24, 40, 0.06);
}

/* Toolbar */
.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.toolbar-actions {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.toolbar-label {
  font-size: 24rpx;
  color: #6b7280;
}

.toolbar-picker {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid rgba(16, 24, 40, 0.12);
  color: #1f2329;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  box-shadow: 0 6rpx 12rpx rgba(16, 24, 40, 0.06);
}
