:root {
  --color-background: #f7f8fa;
  --color-background-strong: #f3f4f7;
  --color-foreground: #1a1a1e;
  --color-card: #ffffff;
  --color-card-foreground: #1a1a1e;
  --color-primary: #d9a42b;
  --color-primary-strong: #fcc419;
  --color-primary-foreground: #ffffff;
  --color-secondary: #f1f3f5;
  --color-muted: #f1f3f5;
  --color-muted-foreground: #8e9aaf;
  --color-accent: #d9a42b;
  --color-destructive: #fa5252;
  --color-success: #22c55e;
  --color-info: #339af0;
  --color-border: #e9ecef;
  --color-soft-gold: #fcf8e8;
  --color-soft-danger: #fff5f5;
  --color-soft-success: #e7f9ee;
  --color-soft-info: #e7f5ff;
  --radius-xs: 12rpx;
  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-xl: 48rpx;
  --shadow-card: 0 8rpx 40rpx rgba(0, 0, 0, 0.04);
  --shadow-soft: 0 6rpx 20rpx rgba(0, 0, 0, 0.03);
  --shadow-gold: 0 10rpx 30rpx rgba(217, 164, 43, 0.2);
  --shadow-floating: 0 18rpx 45rpx rgba(15, 23, 42, 0.08);
}

page {
  background:
    linear-gradient(180deg, #fbfbfc 0%, var(--color-background) 180rpx),
    var(--color-background);
  color: var(--color-foreground);
  font-size: 28rpx;
  line-height: 1.6;
  padding-bottom: 188rpx;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.container {
  padding: 30rpx;
}

.page-root {
  min-height: 100vh;
  background: var(--color-background);
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 188rpx;
  box-sizing: border-box;
  position: relative;
}

.page-shell--white {
  background:
    linear-gradient(180deg, #ffffff 0%, #fafbfc 260rpx),
    #ffffff;
}

.page-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(26rpx);
  opacity: 0.75;
  pointer-events: none;
}

.page-orb--gold {
  width: 260rpx;
  height: 260rpx;
  top: -90rpx;
  right: -70rpx;
  background: rgba(252, 196, 25, 0.14);
}

.page-orb--soft {
  width: 180rpx;
  height: 180rpx;
  top: 200rpx;
  left: -90rpx;
  background: rgba(255, 255, 255, 0.65);
}

.page-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 900;
  color: var(--color-foreground);
  letter-spacing: -0.4rpx;
}

.text-foreground {
  color: var(--color-foreground);
}

.text-muted {
  color: var(--color-muted-foreground);
}

.text-primary {
  color: var(--color-primary);
}

.bg-card {
  background: var(--color-card);
}

.bg-muted {
  background: var(--color-muted);
}

.g-card,
.card {
  position: relative;
  background: var(--color-card);
  color: var(--color-card-foreground);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: var(--shadow-soft);
}

.floating-card {
  background: var(--color-card);
  border-radius: 40rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: var(--shadow-floating);
}

.soft-panel {
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.soft-block {
  background: #f8f9fa;
  border-radius: 28rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.03);
}

.g-card--xl {
  border-radius: var(--radius-xl);
  padding: 36rpx;
  box-shadow: var(--shadow-card);
}

.g-chip {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  background: #fff9db;
  color: var(--color-primary);
  border: 1rpx solid rgba(217, 164, 43, 0.15);
}

.g-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 800;
  border: 1rpx solid transparent;
}

.g-badge--success {
  background: #e7f9ee;
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.15);
}

.g-badge--warning {
  background: #fff9db;
  color: var(--color-primary);
  border-color: rgba(217, 164, 43, 0.2);
}

.g-badge--danger {
  background: #fff5f5;
  color: var(--color-destructive);
  border-color: rgba(250, 82, 82, 0.2);
}

.g-badge--info {
  background: var(--color-soft-info);
  color: var(--color-info);
  border-color: rgba(51, 154, 240, 0.18);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

button {
  font-size: 28rpx;
  border-radius: 999rpx;
}

.btn {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  transition: all 0.2s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #e3b447 0%, var(--color-primary) 100%);
  color: var(--color-primary-foreground);
  box-shadow: var(--shadow-gold);
  padding: 18rpx 28rpx;
}

.btn-secondary {
  background: #ffffff;
  color: var(--color-primary);
  border: 2rpx solid rgba(217, 164, 43, 0.15);
}

.btn-outline {
  border: 2rpx solid rgba(217, 164, 43, 0.35);
  color: var(--color-primary);
  background: #ffffff;
  padding: 16rpx 22rpx;
}

.btn-danger {
  background: var(--color-destructive);
  color: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(250, 82, 82, 0.2);
}

button[disabled] {
  opacity: 0.55;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: var(--color-foreground);
  margin-bottom: 12rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.input,
.textarea,
.picker,
.readonly,
.select {
  background: #f8f9fa;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  color: var(--color-foreground);
}

.readonly {
  color: var(--color-foreground);
}

.textarea {
  min-height: 160rpx;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: var(--color-foreground);
  background: var(--color-muted);
  border: 1rpx solid rgba(0, 0, 0, 0.05);
  font-weight: 700;
}

.status-badge--success {
  color: #22c55e;
  border-color: rgba(34, 197, 94, 0.25);
  background: #e7f9ee;
}

.status-badge--warning {
  color: var(--color-primary);
  border-color: rgba(217, 164, 43, 0.25);
  background: #fff9db;
}

.status-badge--info {
  color: var(--color-info);
  border-color: rgba(51, 154, 240, 0.2);
  background: var(--color-soft-info);
}

.title-xl {
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 900;
  color: var(--color-foreground);
  letter-spacing: -1rpx;
}

.title-lg {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 900;
  color: var(--color-foreground);
}

.eyebrow {
  font-size: 18rpx;
  font-weight: 900;
  color: rgba(142, 154, 175, 0.7);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.icon-circle {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-soft-gold);
  color: var(--color-primary);
  border: 1rpx solid rgba(217, 164, 43, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(217, 164, 43, 0.08);
}

.empty-card {
  padding: 42rpx 32rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx dashed rgba(142, 154, 175, 0.18);
  color: rgba(142, 154, 175, 0.85);
  text-align: center;
}

.status-badge--danger {
  color: var(--color-destructive);
  border-color: rgba(250, 82, 82, 0.25);
  background: #fff5f5;
}

.empty-state,
.loading-state {
  text-align: center;
  padding: 28rpx 24rpx;
  border-radius: var(--radius-lg);
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  color: var(--color-muted-foreground);
  box-shadow: var(--shadow-soft);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.toolbar-actions {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.toolbar-label {
  font-size: 24rpx;
  color: var(--color-muted-foreground);
}

.toolbar-picker {
  padding: 10rpx 14rpx;
  border-radius: 12rpx;
  background: #ffffff;
  border: 1rpx solid rgba(0, 0, 0, 0.12);
  color: var(--color-foreground);
}

.glass {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.card-shadow {
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.04);
}

.gold-gradient {
  background: linear-gradient(135deg, #e7bc4e 0%, #d9a42b 100%);
}

.no-scrollbar::-webkit-scrollbar {
  display: none;
}

.no-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}
