page {
  background: #f5f7fb;
  color: #1f2329;
  font-size: 28rpx;
  line-height: 1.6;
  padding-bottom: 220rpx;
  box-sizing: border-box;
}

.container {
  padding: 32rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(16, 24, 40, 0.08);
  border: 1rpx solid rgba(16, 24, 40, 0.04);
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.text-muted {
  color: #8b929c;
}

/* Buttons */
button {
  font-size: 28rpx;
  border-radius: 999rpx;
}

.btn {
  height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.25);
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
}

.btn-outline {
  border: 2rpx solid #3b82f6;
  color: #2563eb;
  background: #fff;
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
}

button[disabled] {
  opacity: 0.55;
}

/* Form */
.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  color: #5e6572;
  margin-bottom: 12rpx;
  font-size: 26rpx;
}

.input,
.textarea,
.picker,
.readonly {
  background: #f3f4f6;
  border-radius: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.readonly {
  color: #1f2329;
}

.textarea {
  min-height: 160rpx;
}
